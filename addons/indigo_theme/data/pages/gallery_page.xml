<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="view_gallery" name="Gallery / Inspiration">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">

                <!-- Hero -->
                <section class="indigo-hero-fullbleed" style="min-height: 50vh;">
                    <div class="hero-bg" style="background-image: url('/indigo_theme/static/src/img/photo/home-hero-miami-door.jpg');"/>
                    <div class="hero-overlay"/>
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-9 col-xl-8">
                                <div class="indigo-eyebrow" style="color: rgba(255,255,255,0.85) !important;">Inspiration</div>
                                <h1 class="h-display">Doors in the <em>wild.</em></h1>
                                <p class="lead">Real installations across Florida. Browse projects from the dealer network.</p>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Filter pills — compact sticky bar (door type only) -->
                <section class="indigo-gallery-filters sticky-top">
                    <div class="container">
                        <div class="indigo-gallery-filters__row" data-indigo-fade="">
                            <button class="indigo-chip is-active" data-indigo-filter="all">All</button>
                            <button class="indigo-chip" data-indigo-filter="single">Single</button>
                            <button class="indigo-chip" data-indigo-filter="double">Double</button>
                            <button class="indigo-chip" data-indigo-filter="sidelite">Sidelites</button>
                        </div>
                    </div>
                </section>

                <!-- Masonry grid of real installs -->
                <section class="indigo-section">
                    <style>
                        .indigo-gallery-masonry { column-count: 3; column-gap: 1.25rem; }
                        .indigo-gallery-masonry > div { break-inside: avoid; margin-bottom: 1.25rem; }
                        @media (max-width: 992px) { .indigo-gallery-masonry { column-count: 2; } }
                        @media (max-width: 576px) { .indigo-gallery-masonry { column-count: 1; } }
                    </style>
                    <div class="container">
                        <div class="indigo-gallery-masonry">
                            <div data-indigo-fade="" data-delay="100" data-indigo-tags="double">
                                <a href="/shop" class="indigo-gallery-item d-block position-relative" style="border-radius: 1.25rem; overflow: hidden;">
                                    <img src="/indigo_theme/static/src/img/gallery/dd-01.jpg" style="width:100%; height:auto; display:block;" loading="lazy" alt="Double door installation"/>
                                </a>
                            </div>
                            <div data-indigo-fade="" data-delay="180" data-indigo-tags="single">
                                <a href="/shop" class="indigo-gallery-item d-block position-relative" style="border-radius: 1.25rem; overflow: hidden;">
                                    <img src="/indigo_theme/static/src/img/gallery/sd-01.jpg" style="width:100%; height:auto; display:block;" loading="lazy" alt="Single door installation"/>
                                </a>
                            </div>
                            <div data-indigo-fade="" data-delay="260" data-indigo-tags="sidelite">
