<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_indigo" model="ir.ui.view">
        <field name="name">res.partner.form.indigo</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Indigo Dealer" name="indigo_dealer" invisible="not is_indigo_dealer">
                    <group>
                        <group>
                            <field name="is_indigo_dealer"/>
                            <field name="indigo_dealer_code"/>
                            <field name="indigo_default_price_per_sqf"/>
                        </group>
                        <group>
                            <button name="action_indigo_create_portal_user" type="object"
                                    string="Crear acceso portal" class="btn btn-primary"
                                    confirm="Esto creara un usuario portal con el email del contacto y enviara un correo de bienvenida."/>
                        </group>
                    </group>
                    <separator string="Etapas opcionales activas"/>
                    <field name="indigo_optional_stage_ids" widget="many2many_tags"/>
                </page>
            </xpath>
            <xpath expr="//field[@name='vat']" position="after">
                <field name="is_indigo_dealer"/>
            </xpath>
        </field>
    </record>

    <!-- Dedicated tree view for Indigo dealers: shows price/SQF, dealer code,
         and a 'DEMO DATA' tag on rows that are still seed/placeholder so the
         team knows to replace them before go-live. -->
    <record id="view_indigo_dealer_tree" model="ir.ui.view">
        <field name="name">indigo.dealer.tree</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <tree string="Indigo Dealers" decoration-warning="indigo_is_demo_data">
                <field name="indigo_dealer_code" string="Code"/>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="city"/>
                <field name="indigo_default_price_per_sqf" string="$/SQF" sum="$/SQF"/>
                <field name="indigo_is_demo_data" string="Demo data" widget="boolean_toggle" readonly="1"/>
            </tree>
        </field>
    </record>

    <record id="action_indigo_dealer" model="ir.actions.act_window">
        <field name="name">Dealers</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="view_id" ref="view_indigo_dealer_tree"/>
        <field name="domain">[('is_indigo_dealer', '=', True)]</field>
        <field name="context">{'default_is_indigo_dealer': True, 'default_is_company': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No hay dealers cargados todavia.</p>
            <p>
                Cargar aqui los dealers reales (Lock Tight, USA Windows, Web Indigo,
                etc.) con sus emails corporativos, telefonos, direcciones y la
                tarifa por SQF acordada con cada uno.
            </p>
            <p>
                <strong style="color:#b45309;">Las filas en amarillo son DATA DEMO</strong> —
                tienen email <code>.example</code> o falta direccion. Reemplazar
                con datos reales antes de ir a produccion con clientes reales.
            </p>
        </field>
    </record>

</odoo>
