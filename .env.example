# Indigo Decors - Variables de entorno
# Copiar a .env y rellenar valores reales.

# --- DB ---
POSTGRES_USER=odoo
POSTGRES_PASSWORD=changeme_strong_password_here
POSTGRES_HOST_PORT=5433

# --- Odoo ---
ODOO_HOST_PORT=8069
ODOO_LONGPOLLING_PORT=8072

# --- GitHub (deploy / scripts) ---
GITHUB_USER=
GITHUB_TOKEN=
GITHUB_REPO=

# --- SMTP produccion (descomentar y configurar) ---
# Estos los carga Odoo desde config/odoo.conf, no de env.
# Edita config/odoo.conf con los valores reales.
# Ejemplo Gmail:
#   smtp_server = smtp.gmail.com
#   smtp_port = 587
#   smtp_user = noreply@indigodecors.com
#   smtp_password = <app password>
# Ejemplo SendGrid:
#   smtp_server = smtp.sendgrid.net
#   smtp_port = 587
#   smtp_user = apikey
#   smtp_password = <SG.xxxxx>

# --- Twilio (cuando se active) ---
# Estos los carga Odoo desde ir.config_parameter, NO env.
# Una vez Odoo arriba: Settings > Tecnico > Parametros del sistema:
#   indigo.twilio_account_sid     = ACxxxxxxxxxx
#   indigo.twilio_auth_token      = xxxxxxxxx
#   indigo.twilio_sms_from        = +1xxxxxxxxxx
#   indigo.twilio_whatsapp_from   = +14155238886
