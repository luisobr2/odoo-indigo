<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Custom 404 page — editorial, branded, helpful.
         Overrides Odoo's http_routing.404 (the one that actually
         renders the page with the wrap div; website.page_404 is the
         inner edit-banner template used inside it). -->
    <template id="indigo_404" name="Indigo 404"
              inherit_id="http_routing.404" priority="50">
        <xpath expr="//div[@id='wrap']" position="replace">
            <div id="wrap" class="oe_structure">
                <section class="indigo-section text-center" style="min-height: 70vh; display:flex; align-items:center;">
                    <div class="container" style="max-width: 640px;">
                        <div class="indigo-eyebrow indigo-eyebrow--numbered" data-num="404">Page not found</div>
                        <h1 class="h-display display-2 mb-4">This door doesn't open.</h1>
                        <p class="lead text-muted mb-5">
                            The page you were looking for isn't here. It may have been moved,
                            renamed, or perhaps it was never quoted to spec.
                        </p>
                        <div class="d-flex gap-3 justify-content-center flex-wrap">
                            <a href="/" class="btn btn-primary btn-lg">Back to home</a>
                            <a href="/shop" class="btn btn-outline-primary btn-lg">Browse the catalog</a>
                        </div>
                        <hr class="indigo-hairline mt-5"/>
                        <p class="small text-muted mt-4 mb-0">
                            Looking for something specific?
                            <a href="/contactus" class="text-decoration-underline">Reach our team</a>
                            — we reply within 24 business hours.
                        </p>
                    </div>
                </section>
            </div>
        </xpath>
    </template>

</odoo>
