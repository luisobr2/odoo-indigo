<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        CUSTOM design family
        ====================
        Used when a dealer brings a one-off design that isn't in the
        standard catalogue. The operator picks CUSTOM-SD or CUSTOM-DD,
        attaches the photo the client sent, and proceeds as usual.

        Notes on storage:
          * `indigo.design` has an `image` field (NOT `image_1920`), but
            the catalog API serves images from `ir.attachment` records
            linked via res_model/res_id. So we add the cover images as
            attachments — the same pattern operators use to upload extra
            shots from the UI.

        Two <data> blocks so noupdate applies cleanly:
          * Designs noupdate="1": preserve Majela's manual edits across upgrades.
          * Attachments noupdate="0": let updated placeholder jpegs propagate.
    -->

    <data noupdate="1">
        <record id="design_custom_sd" model="indigo.design">
            <field name="code">CUSTOM-SD</field>
            <field name="name">Custom Design — Single Door</field>
            <field name="door_type">SD</field>
            <field name="description">Catalog-free single door. Attach the photo or sketch the dealer sent when creating the order.</field>
        </record>

        <record id="design_custom_dd" model="indigo.design">
            <field name="code">CUSTOM-DD</field>
            <field name="name">Custom Design — Double Door</field>
            <field name="door_type">DD</field>
            <field name="description">Catalog-free double door. Attach the photo or sketch the dealer sent when creating the order.</field>
        </record>
    </data>

    <data noupdate="0">
        <record id="attach_custom_sd_cover" model="ir.attachment">
            <field name="name">custom-sd.jpeg</field>
            <field name="res_model">indigo.design</field>
            <field name="res_id" ref="design_custom_sd"/>
            <field name="type">binary</field>
            <field name="mimetype">image/jpeg</field>
            <field name="datas" type="base64" file="indigo_decors/static/img/custom-design/custom-sd.jpeg"/>
        </record>

        <record id="attach_custom_dd_cover" model="ir.attachment">
            <field name="name">custom-dd.jpeg</field>
            <field name="res_model">indigo.design</field>
            <field name="res_id" ref="design_custom_dd"/>
            <field name="type">binary</field>
            <field name="mimetype">image/jpeg</field>
            <field name="datas" type="base64" file="indigo_decors/static/img/custom-design/custom-dd.jpeg"/>
        </record>
    </data>

</odoo>
