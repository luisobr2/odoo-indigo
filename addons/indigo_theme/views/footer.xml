<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Estrategia: ocultamos el footer default via clase y agregamos nuestro footer custom
         como hermano dentro de website.layout. -->

    <template id="indigo_footer_inject" name="Indigo Footer Custom"
              inherit_id="website.layout" priority="51">
        <xpath expr="//footer" position="after">
            <footer id="indigo_footer" class="indigo-footer-custom">
                <section class="indigo-footer-main py-5">
                    <div class="container">
                        <div class="row g-4 g-lg-5">
                            <!-- Col 1: Brand + tagline + social -->
                            <div class="col-lg-4 col-md-6 mb-4">
                                <a href="/" class="d-inline-block mb-3">
                                    <img src="/indigo_theme/static/src/img/logo.png" alt="Indigo Decors" style="max-height: 56px; filter: brightness(0) invert(1);"/>
                                </a>
                                <p class="text-white-50 small mb-4" style="max-width: 320px;">
                                    Decorative high-impact doors for residential and commercial projects across Florida. Hand-crafted in Miami.
                                </p>
                                <div class="d-flex gap-2">
                                    <a href="#" aria-label="Facebook" class="indigo-social-icon">
                                        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.04c-5.5 0-9.96 4.46-9.96 9.96 0 4.96 3.64 9.07 8.4 9.84v-6.96h-2.52v-2.88h2.52V9.84c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.23.19 2.23.19v2.45h-1.25c-1.24 0-1.63.77-1.63 1.56v1.87h2.77l-.44 2.88h-2.33v6.96c4.76-.77 8.4-4.88 8.4-9.84 0-5.5-4.46-9.96-9.96-9.96z"/></svg>
                                    </a>
                                    <a href="#" aria-label="Instagram" class="indigo-social-icon">
                                        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.72 3.72 0 01-1.38-.9 3.71 3.71 0 01-.9-1.38c-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zm0 3.45a6.39 6.39 0 100 12.78 6.39 6.39 0 000-12.78zm0 10.55a4.16 4.16 0 110-8.32 4.16 4.16 0 010 8.32z"/></svg>
                                    </a>
                                    <a href="#" aria-label="Twitter" class="indigo-social-icon">
                                        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05A4.28 4.28 0 0015.5 4a4.29 4.29 0 00-4.29 4.29c0 .34.04.67.11.99A12.18 12.18 0 013 5.16a4.29 4.29 0 001.33 5.73 4.27 4.27 0 01-1.94-.54v.05A4.29 4.29 0 005.83 14.6a4.3 4.3 0 01-1.93.07 4.3 4.3 0 004.01 2.98A8.6 8.6 0 012 19.54 12.13 12.13 0 008.56 21.5c7.88 0 12.19-6.53 12.19-12.19 0-.19 0-.37-.01-.56A8.7 8.7 0 0022.46 6z"/></svg>
                                    </a>
                                    <a href="#" aria-label="LinkedIn" class="indigo-social-icon">
                                        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M19 3a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h14m-.5 15.5v-5.3a3.26 3.26 0 00-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 011.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 001.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 00-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/></svg>
                                    </a>
                                </div>
                            </div>

                            <!-- Col 2: Shop -->
                            <div class="col-lg-2 col-md-6 col-6">
                                <h4 class="indigo-footer-heading">Shop</h4>
                                <ul class="indigo-footer-list">
                                    <li><a href="/shop">All doors</a></li>
                                    <li><a href="/shop">Single doors</a></li>
                                    <li><a href="/shop">Double doors</a></li>
                                    <li><a href="/shop">Sidelites</a></li>
                                    <li><a href="/shop">Custom orders</a></li>
                                </ul>
                            </div>

                            <!-- Col 3: For Pros -->
                            <div class="col-lg-2 col-md-6 col-6">
                                <h4 class="indigo-footer-heading">For Pros</h4>
                                <ul class="indigo-footer-list">
                                    <li><a href="#">Dealer Program</a></li>
                                    <li><a href="/web/login">Dealer Login</a></li>
                                    <li><a href="#">Wholesale Pricing</a></li>
                                    <li><a href="#">Catalog Download</a></li>
                                </ul>
                            </div>

                            <!-- Col 4: Contact + Newsletter -->
                            <div class="col-lg-4 col-md-6">
                                <h4 class="indigo-footer-heading">Get in touch</h4>
                                <ul class="indigo-footer-list mb-4">
                                    <li>
                                        <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24" class="me-2"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                                        <a href="tel:+17863002752">+1 786-300-2752</a>
                                    </li>
                                    <li>
                                        <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24" class="me-2"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                                        <a href="mailto:sales@indigodecors.com">sales@indigodecors.com</a>
                                    </li>
                                    <li>
                                        <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24" class="me-2"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 010-5 2.5 2.5 0 010 5z"/></svg>
                                        Miami, FL · USA
                                    </li>
                                </ul>
                                <p class="text-white-50 small mb-2">Subscribe for new designs &amp; hurricane prep tips. No spam.</p>
                                <form class="d-flex gap-2 align-items-center">
                                    <input type="email" name="email" placeholder="your@email.com" class="form-control form-control-sm flex-grow-1" style="max-width:220px;"/>
                                    <button type="submit" class="btn btn-primary btn-sm">Join</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="indigo-footer-bottom py-3">
                    <div class="container d-flex flex-wrap justify-content-between align-items-center gap-2 small">
                        <div class="text-white-50">© 2026 Indigo Decors. All rights reserved. Made in Miami, FL.</div>
                        <div class="d-flex gap-3">
                            <a href="#" class="text-white-50 text-decoration-none">Privacy</a>
                            <a href="#" class="text-white-50 text-decoration-none">Terms</a>
                            <a href="#" class="text-white-50 text-decoration-none">Cookies</a>
                            <a href="#" class="text-white-50 text-decoration-none">Accessibility</a>
                        </div>
                    </div>
                </section>
            </footer>
        </xpath>
    </template>

</odoo>
