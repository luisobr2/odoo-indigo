<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Pagina Dealer Program -->
    <template id="view_dealer_program" name="Dealer Program">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">

                <!-- Hero -->
                <section class="indigo-hero-fullbleed" style="min-height: 60vh;">
                    <div class="hero-bg" style="background-image: url('https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=2400&amp;q=85');"/>
                    <div class="hero-overlay"/>
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-8">
                                <div class="indigo-eyebrow" style="color: rgba(255,255,255,0.85) !important;">Indigo Dealer Program</div>
                                <h1 class="h-display">For pros who <em>sell at scale.</em></h1>
                                <p class="lead">Join the 15+ Florida dealers offering Indigo high-impact doors. Wholesale pricing, custom branding, dedicated account manager.</p>
                                <div class="d-flex flex-wrap gap-3 mt-4">
                                    <a href="#apply" class="btn btn-light btn-lg">Apply now →</a>
                                    <a href="#benefits" class="btn btn-outline-light btn-lg">Learn more</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Benefits grid -->
                <section id="benefits" class="indigo-section">
                    <div class="container">
                        <div class="text-center mb-5" data-indigo-fade="">
                            <div class="indigo-eyebrow">Why Indigo</div>
                            <h2 class="h-display display-3 mb-3">Built for distributors.</h2>
                            <p class="lead text-muted" style="max-width: 700px; margin: 0 auto;">
                                Everything you need to grow your impact-door business in Florida.
                            </p>
                        </div>
                        <div class="row g-4">
                            <div class="col-md-6 col-lg-4" data-indigo-fade="" data-delay="100">
                                <div class="indigo-tile">
                                    <div style="aspect-ratio: 16/10; background: linear-gradient(135deg, #1f4486, #3a5ea3); border-radius: 1.5rem; display:flex; align-items:center; justify-content:center; color:#fff; font-size: 3rem; margin-bottom: 1rem;">💰</div>
                                    <h3>Wholesale pricing</h3>
                                    <p>Up to 30% off MSRP on volume orders. Tier-based pricing rewards loyalty.</p>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-4" data-indigo-fade="" data-delay="200">
                                <div class="indigo-tile">
                                    <div style="aspect-ratio: 16/10; background: linear-gradient(135deg, #1f4486, #3a5ea3); border-radius: 1.5rem; display:flex; align-items:center; justify-content:center; color:#fff; font-size: 3rem; margin-bottom: 1rem;">📊</div>
                                    <h3>Real-time tracking</h3>
                                    <p>Order dashboard from CNC cut to installation. Photo updates at each stage.</p>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-4" data-indigo-fade="" data-delay="300">
                                <div class="indigo-tile">
                                    <div style="aspect-ratio: 16/10; background: linear-gradient(135deg, #1f4486, #3a5ea3); border-radius: 1.5rem; display:flex; align-items:center; justify-content:center; color:#fff; font-size: 3rem; margin-bottom: 1rem;">🎨</div>
                                    <h3>Co-branded materials</h3>
                                    <p>Brochures, samples and showroom displays with your logo.</p>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-4" data-indigo-fade="" data-delay="100">
                                <div class="indigo-tile">
                                    <div style="aspect-ratio: 16/10; background: linear-gradient(135deg, #1f4486, #3a5ea3); border-radius: 1.5rem; display:flex; align-items:center; justify-content:center; color:#fff; font-size: 3rem; margin-bottom: 1rem;">⚡</div>
                                    <h3>14-day production</h3>
                                    <p>Standard lead time from order to installation. Priority queue for top dealers.</p>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-4" data-indigo-fade="" data-delay="200">
                                <div class="indigo-tile">
                                    <div style="aspect-ratio: 16/10; background: linear-gradient(135deg, #1f4486, #3a5ea3); border-radius: 1.5rem; display:flex; align-items:center; justify-content:center; color:#fff; font-size: 3rem; margin-bottom: 1rem;">🛡️</div>
                                    <h3>10-year warranty</h3>
                                    <p>Florida HVHZ approved. Every door comes with our full guarantee.</p>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-4" data-indigo-fade="" data-delay="300">
                                <div class="indigo-tile">
                                    <div style="aspect-ratio: 16/10; background: linear-gradient(135deg, #1f4486, #3a5ea3); border-radius: 1.5rem; display:flex; align-items:center; justify-content:center; color:#fff; font-size: 3rem; margin-bottom: 1rem;">👨‍💼</div>
                                    <h3>Account manager</h3>
                                    <p>Direct line to a dedicated person who knows your account and projects.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Apply form -->
                <section id="apply" class="indigo-section bg-soft">
                    <div class="container">
                        <div class="row g-5 align-items-center">
                            <div class="col-lg-5" data-indigo-fade="">
                                <div class="indigo-eyebrow">Get started</div>
                                <h2 class="h-display display-4 mb-3">Apply to become a dealer.</h2>
                                <p class="lead text-muted mb-4">
                                    Tell us about your business. We respond within 48 business hours.
                                </p>
                                <ul class="list-unstyled">
                                    <li class="mb-2">✓ Active business license required</li>
                                    <li class="mb-2">✓ Florida-based or able to install in FL</li>
                                    <li class="mb-2">✓ Showroom or design studio preferred</li>
                                </ul>
                            </div>
                            <div class="col-lg-7" data-indigo-fade="" data-delay="200">
                                <div class="card border-0 shadow-lg p-4 p-md-5" style="border-radius: 1.5rem;">
                                    <form action="/website/form/" method="post">
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label small fw-bold">Company name *</label>
                                                <input class="form-control" name="company_name" required="required"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small fw-bold">Contact name *</label>
                                                <input class="form-control" name="contact_name" required="required"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small fw-bold">Email *</label>
                                                <input type="email" class="form-control" name="email" required="required"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small fw-bold">Phone</label>
                                                <input class="form-control" name="phone"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small fw-bold">City / State</label>
                                                <input class="form-control" name="city" placeholder="Miami, FL"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small fw-bold">Years in business</label>
                                                <select class="form-control" name="years">
                                                    <option>Less than 1 year</option>
                                                    <option>1-3 years</option>
                                                    <option>3-10 years</option>
                                                    <option>10+ years</option>
                                                </select>
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label small fw-bold">Tell us about your business *</label>
                                                <textarea class="form-control" name="message" rows="4" required="required" placeholder="What kind of projects you do, expected volume, etc."></textarea>
                                            </div>
                                            <div class="col-12">
                                                <button type="submit" class="btn btn-primary btn-lg w-100">Submit application →</button>
                                                <p class="small text-muted mt-2 mb-0 text-center">We'll respond within 48 hours.</p>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

            </div>
        </t>
    </template>

    <record id="page_dealer_program" model="website.page">
        <field name="view_id" ref="view_dealer_program"/>
        <field name="url">/page/dealer-program</field>
        <field name="is_published" eval="True"/>
    </record>

</odoo>
