                        <div class="d-flex gap-3">
                            <a href="#">Privacy</a>
                            <a href="#">Terms</a>
                            <a href="#">Cookies</a>
                            <a href="#">Accessibility</a>
                        </div>
                    </div>
                </section>
            </footer>
        </xpath>
    </template>

</odoo>
