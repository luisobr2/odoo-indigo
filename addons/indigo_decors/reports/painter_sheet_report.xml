<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_painter_sheet" model="ir.actions.report">
        <field name="name">Hoja del pintor</field>
        <field name="model">indigo.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">indigo_decors.report_painter_sheet_doc</field>
        <field name="report_file">indigo_decors.report_painter_sheet_doc</field>
        <field name="binding_model_id" ref="model_indigo_order"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_us"/>
    </record>

    <template id="report_painter_sheet_doc">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2 style="color:#1f4486;">Hoja del Pintor</h2>
                    <p style="color:#666;">
                        Tarifa fija: <strong>$8 USD / SQF</strong>
                    </p>

                    <!-- Foto + Brand columns added per Majela's request:
                         Mario picks the bronze tone based on the brand
                         (ESW/SUNSHINE/ECO differ even with same "bronze"),
                         and the photo is his visual guide while painting. -->
                    <table class="table table-sm" style="border: 1px solid #ddd;">
                        <thead style="background-color: #1f4486; color: white;">
                            <tr>
                                <th>Company</th>
                                <th>Order Refs</th>
                                <th>Foto</th>
                                <th>Client</th>
                                <th>Brand</th>
                                <th>Color</th>
                                <th>Door Type</th>
                                <th class="text-end">SQF</th>
                                <th class="text-end">Price</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="grand_sqf" t-value="0"/>
                            <t t-set="grand_total" t-value="0"/>
                            <t t-foreach="docs" t-as="o">
                                <t t-foreach="o.line_ids" t-as="l">
                                    <t t-set="line_total" t-value="(l.sqf or 0) * 8.0"/>
                                    <t t-set="grand_sqf" t-value="grand_sqf + (l.sqf or 0)"/>
                                    <t t-set="grand_total" t-value="grand_total + line_total"/>
                                    <!-- Prefer the order's uploaded photo over the design
                                         placeholder for CUSTOM designs (or when no design image
                                         exists) — Mario paints the door the dealer sent, not
                                         the generic catalog placeholder. -->
                                    <t t-set="is_custom" t-value="(l.design_id.code or '').upper().startswith('CUSTOM')"/>
                                    <t t-set="design_att" t-value="o.env['ir.attachment'].sudo().search([('res_model', '=', 'indigo.design'), ('res_id', '=', l.design_id.id)], order='id desc', limit=1)"/>
                                    <t t-if="is_custom or not design_att">
                                        <t t-set="order_att" t-value="o.env['ir.attachment'].sudo().search([('res_model', '=', 'indigo.order'), ('res_id', '=', o.id), ('mimetype', 'ilike', 'image/%')], order='id asc', limit=1)"/>
                                        <t t-if="order_att" t-set="design_att" t-value="order_att"/>
                                    </t>
                                    <tr>
                                        <td t-out="o.dealer_id.name or ''"/>
                                        <!-- Stack the 3 reference codes: dealer's own ref,
                                             Indigo's system order #, and the customer's PO. -->
                                        <td>
                                            <div t-if="o.dealer_ref" style="font-weight: bold;" t-out="o.dealer_ref"/>
                                            <div t-attf-style="font-size: #{'10px;color:#888' if o.dealer_ref else '12px'}" t-out="o.name or ''"/>
                                            <div t-if="o.customer_po" style="font-size: 9px; color: #888;">PO: <span t-out="o.customer_po"/></div>
                                        </td>
                                        <td style="text-align: center; padding: 4px; width: 70px;">
                                            <img t-if="design_att" t-attf-src="data:#{design_att.mimetype or 'image/jpeg'};base64,#{(design_att.datas or b'').decode()}" style="max-height: 55px; max-width: 55px; object-fit: contain;"/>
                                            <span t-if="not design_att" style="color: #aaa; font-size: 9px;">—</span>
                                        </td>
                                        <td t-out="l.customer_name or o.client_name or ''"/>
                                        <td t-out="l.brand_id.name or ''"/>
                                        <td>
                                            <span t-out="l.color or ''"/>
                                            <t t-if="l.color == 'custom'"> (<span t-out="l.color_custom or ''"/>)</t>
                                        </td>
                                        <td t-out="l.door_type or ''"/>
                                        <td class="text-end" t-out="'%.2f' % (l.sqf or 0)"/>
                                        <td class="text-end">$8.00</td>
                                        <td class="text-end" t-out="'$%.2f' % line_total"/>
                                    </tr>
                                </t>
                            </t>
                        </tbody>
                        <tfoot>
                            <tr style="background-color: #f5f7fb; font-weight: bold;">
                                <td colspan="7" class="text-end">TOTAL:</td>
                                <td class="text-end" t-out="'%.2f' % grand_sqf"/>
                                <td/>
                                <td class="text-end" t-out="'$%.2f' % grand_total"/>
                            </tr>
                        </tfoot>
                    </table>

                    <div style="margin-top: 24px; font-size: 11px; color:#888;">
                        Pago contra entrega del trabajo terminado.
                    </div>
                </div>
            </t>
        </t>
    </template>

</odoo>
