<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_indigo_payout_tree" model="ir.ui.view">
        <field name="name">indigo.payout.tree</field>
        <field name="model">indigo.payout</field>
        <field name="arch" type="xml">
            <tree decoration-info="state == 'draft'" decoration-success="state == 'paid'" decoration-warning="state == 'approved'" decoration-muted="state == 'cancel'">
                <field name="name"/>
                <field name="contractor_id"/>
                <field name="contractor_type"/>
                <field name="date"/>
                <field name="period_start" optional="hide"/>
                <field name="period_end" optional="hide"/>
                <field name="amount" sum="Total"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="view_indigo_payout_form" model="ir.ui.view">
        <field name="name">indigo.payout.form</field>
        <field name="model">indigo.payout</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" string="Aprobar" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_mark_paid" string="Marcar pagada" type="object" class="oe_highlight" invisible="state != 'approved'"/>
                    <button name="action_cancel" string="Cancelar" type="object" invisible="state in ('paid', 'cancel')"/>
                    <button name="action_reset_to_draft" string="Pasar a borrador" type="object" invisible="state not in ('approved', 'cancel')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,approved,paid"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="contractor_id" options="{'no_create_edit': True}"/>
                            <field name="contractor_type"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="period_start"/>
                            <field name="period_end"/>
                            <field name="amount" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lineas" name="lines">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="date_work"/>
                                    <field name="order_id" options="{'no_create_edit': True}"/>
                                    <field name="description"/>
                                    <field name="quantity"/>
                                    <field name="rate"/>
                                    <field name="amount" sum="Total"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notas" name="notes">
                            <field name="notes" placeholder="Notas adicionales..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_indigo_payout_search" model="ir.ui.view">
        <field name="name">indigo.payout.search</field>
        <field name="model">indigo.payout</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="contractor_id"/>
                <filter string="Borrador" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Aprobadas" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Pagadas" name="paid" domain="[('state', '=', 'paid')]"/>
                <separator/>
                <filter string="Pintor" name="painter" domain="[('contractor_type', '=', 'painter')]"/>
                <filter string="Instalador" name="installer" domain="[('contractor_type', '=', 'installer')]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Contratista" name="group_contractor" context="{'group_by': 'contractor_id'}"/>
                    <filter string="Tipo" name="group_type" context="{'group_by': 'contractor_type'}"/>
                    <filter string="Estado" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_indigo_payout_graph" model="ir.ui.view">
        <field name="name">indigo.payout.graph</field>
        <field name="model">indigo.payout</field>
        <field name="arch" type="xml">
            <graph string="Liquidaciones" type="bar">
                <field name="contractor_id" type="row"/>
                <field name="amount" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_indigo_payout_pivot" model="ir.ui.view">
        <field name="name">indigo.payout.pivot</field>
        <field name="model">indigo.payout</field>
        <field name="arch" type="xml">
            <pivot string="Liquidaciones">
                <field name="contractor_id" type="row"/>
                <field name="contractor_type" type="col"/>
                <field name="amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_indigo_payout" model="ir.actions.act_window">
        <field name="name">Liquidaciones</field>
        <field name="res_model">indigo.payout</field>
        <field name="view_mode">tree,form,graph,pivot</field>
        <field name="search_view_id" ref="view_indigo_payout_search"/>
        <field name="context">{"search_default_draft": 1}</field>
    </record>

</odoo>
