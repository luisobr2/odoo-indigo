<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Disable Odoo's "no_footer" on address page (causes huge gap between
         form and our custom footer because main is sized to 100vh) -->
    <template id="address_show_footer"
              inherit_id="website_sale.address"
              name="Indigo: re-enable footer on address">
        <xpath expr="//t[@t-set='no_footer']" position="replace">
            <t t-set="no_footer" t-value="0"/>
        </xpath>
    </template>

    <!-- Restore proper label for company_name (was overwritten by placeholder script) -->
    <template id="address_company_label_fix"
              inherit_id="website_sale.address"
              name="Indigo: fix company_name label">
        <xpath expr="//label[@for='company_name']" position="replace">
            <label class="col-form-label fw-normal label-optional" for="company_name">Company</label>
        </xpath>
    </template>

    <!-- Indigo B2B: VAT is not used; ship-to-same-address checkbox does not
         fit our workflow (most orders ship to the homeowner or the dealer's
         warehouse, NOT to the dealer's billing address). Hide both. -->
    <template id="address_hide_vat_and_shipsame"
              inherit_id="website_sale.address"
              name="Indigo: hide VAT and 'ship same' checkbox">
        <xpath expr="//div[@id='div_vat']" position="attributes">
            <attribute name="style">display: none !important;</attribute>
        </xpath>
        <xpath expr="//div[@id='shipping_use_same']" position="attributes">
            <attribute name="style">display: none !important;</attribute>
        </xpath>
    </template>

    <!-- Add order summary in the empty right column of /shop/address -->
    <template id="address_add_summary"
              inherit_id="website_sale.address"
              name="Indigo: add order summary on address page">
        <xpath expr="//div[hasclass('oe_cart')]" position="after">
            <div class="col-12 col-lg-4 mt-4 mt-lg-0" t-if="website_sale_order and website_sale_order.website_order_line">
                <div class="o_total_card card sticky-lg-top border-0 shadow-sm" style="top: 90px;">
                    <div class="card-body p-3 p-lg-4">
                        <h5 class="mb-3 fw-bold">Resumen del pedido</h5>
                        <div class="mb-3">
                            <t t-foreach="website_sale_order.website_order_line" t-as="line">
                                <div class="d-flex align-items-center mb-2 pb-2 border-bottom">
                                    <div style="width:48px;height:48px;flex-shrink:0;" class="me-2 rounded overflow-hidden bg-light">
                                        <img t-att-src="'/web/image/product.product/%s/image_128' % line.product_id.id"
                                             style="width:100%;height:100%;object-fit:cover;" alt=""/>
                                    </div>
                                    <div class="flex-grow-1 small">
                                        <div class="fw-bold text-truncate" t-out="line.product_id.display_name"/>
                                        <div class="text-muted">
                                            <span t-out="int(line.product_uom_qty)"/> ×
                                            <span t-field="line.price_unit"
                                                  t-options='{"widget":"monetary","display_currency":website_sale_order.currency_id}'/>
                                        </div>
                                    </div>
                                    <div class="small fw-bold ms-2">
                                        <span t-field="line.price_subtotal"
                                              t-options='{"widget":"monetary","display_currency":website_sale_order.currency_id}'/>
                                    </div>
                                </div>
                            </t>
                        </div>
                        <div class="d-flex justify-content-between small mb-1">
                            <span>Subtotal</span>
                            <span t-field="website_sale_order.amount_untaxed"
                                  t-options='{"widget":"monetary","display_currency":website_sale_order.currency_id}'/>
                        </div>
                        <div class="d-flex justify-content-between small mb-3 text-muted">
                            <span>Impuestos</span>
                            <span t-field="website_sale_order.amount_tax"
                                  t-options='{"widget":"monetary","display_currency":website_sale_order.currency_id}'/>
                        </div>
                        <div class="d-flex justify-content-between fw-bold h5 mb-0 pt-3 border-top">
                            <span>Total</span>
                            <span t-field="website_sale_order.amount_total"
                                  t-options='{"widget":"monetary","display_currency":website_sale_order.currency_id}'/>
                        </div>
                        <a href="/shop/cart" class="btn btn-link btn-sm p-0 mt-3 text-decoration-none">← Editar carrito</a>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

</odoo>
