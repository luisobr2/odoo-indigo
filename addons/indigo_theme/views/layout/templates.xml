<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inject CSS directo en <head> (fallback: garantiza estilos aun si el
         theme no se aplica via Website UI o si el SCSS bundle no recompila). -->
    <template id="indigo_inject_css" name="Indigo CSS Fallback"
              inherit_id="website.layout" priority="49">
        <xpath expr="//head" position="inside">
            <link rel="stylesheet" type="text/css" href="/indigo_theme/static/src/css/theme.css?v=72"/>
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700;800;900&amp;family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&amp;display=swap" rel="stylesheet"/>
            <!-- Inline suppressor must run BEFORE Odoo lazy bundle so it can
                 catch the harmless null.remove() unhandled rejection that
                 otherwise pops a scary "Odoo Client Error" dialog on portal
                 pages. Keep this tiny and inline (no extra HTTP request). -->
            <script>
                (function(){
                    window.addEventListener('unhandledrejection', function(ev){
                        try {
                            var m = (ev.reason &amp;&amp; ev.reason.message) || String(ev.reason || '');
                            if (/Cannot read properties of null \(reading ['"]remove['"]\)/.test(m)) {
                                ev.preventDefault();
                                ev.stopImmediatePropagation &amp;&amp; ev.stopImmediatePropagation();
                            }
                        } catch(e){}
                    }, true);
                    window.addEventListener('error', function(ev){
                        try {
                            var m = ev.message || '';
                            if (/Cannot read properties of null \(reading ['"]remove['"]\)/.test(m)) {
                                ev.preventDefault();
                                ev.stopImmediatePropagation &amp;&amp; ev.stopImmediatePropagation();
                            }
                        } catch(e){}
                    }, true);
                })();
            </script>
            <script src="/indigo_theme/static/src/js/theme.js?v=28" defer="defer"/>
        </xpath>
    </template>

