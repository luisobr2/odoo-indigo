                            <span>+1 (305) 785-6666</span>
                        </a>
                        <span class="text-white-50" aria-hidden="true">·</span>
                        <a href="tel:+17863022732" class="text-white text-decoration-none d-inline-flex align-items-center gap-2">
                            <svg width="13" height="13" fill="currentColor" viewBox="0 0 24 24"><path d="M16 3h4a1 1 0 011 1v16a1 1 0 01-1 1h-4a1 1 0 01-1-1V4a1 1 0 011-1zm1 2v14h2V5h-2zM3 5a2 2 0 012-2h7.5l-.001 2H5v14h7.5l.001 2H5a2 2 0 01-2-2V5z"/></svg>
                            <span>+1 (786) 302-2732</span>
                        </a>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

