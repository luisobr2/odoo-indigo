<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- "Price on request" notice above the Add-to-cart block.
         Cart works normally; final pricing is set by sales after the
         customer submits the cart as a quote request. -->
    <template id="indigo_product_quote_notice" name="Indigo Product Quote Notice"
              inherit_id="website_sale.product_buy_now" priority="40">
        <xpath expr="." position="before">
            <div class="indigo-pdp-quote-block mb-3">
                <span class="indigo-price-on-request">Price set after submission — based on dealer, finish, glass &amp; SQF</span>
                <p class="small text-muted mt-2 mb-0">
                    Add doors to your quote list, submit your shipping info, and our
                    sales team will reply within 24 hours with personalized pricing
                    and payment instructions.
                </p>
            </div>
        </xpath>
    </template>

    <!-- (PDP trust-badges removed: contained unverified claims like
         "Hurricane-tested · HVHZ approved", "10-year warranty",
         "14-day install", "Free delivery". To be re-introduced only
         when the client confirms each claim with documentation.) -->

</odoo>
