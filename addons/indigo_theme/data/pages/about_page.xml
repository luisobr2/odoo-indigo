<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="view_about" name="About Us">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">

                <!-- Hero editorial -->
                <section class="indigo-hero-fullbleed" style="min-height: 70vh;">
                    <div class="hero-bg" style="background-image: url('/indigo_theme/static/src/img/photo/about-hero-workshop.jpg');"/>
                    <div class="hero-overlay"/>
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-9 col-xl-8">
                                <div class="indigo-eyebrow" style="color: rgba(255,255,255,0.85) !important;">Our story</div>
                                <h1 class="h-display">Crafted in Miami.<br/><em>Built for Florida.</em></h1>
                                <p class="lead">Indigo Decors is a Miami workshop turning ordinary entrances into statements. Hand-crafted decorative doors.</p>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- About Us — corporate copy (consistent with prior site) -->
                <section class="indigo-section">
                    <div class="container" style="max-width: 920px;">
                        <div class="text-center mb-5" data-indigo-fade="">
                            <div class="indigo-eyebrow">About us</div>
                            <h2 class="h-display display-3 mb-4">A creative and passionate <em>design company.</em></h2>
                        </div>
                        <div data-indigo-fade="" data-delay="100">
                            <p class="lead text-muted mb-4">
                                <strong class="text-dark">Indigo Decors</strong> is a creative and passionate design company dedicated to bringing originality and beauty into everyday spaces. We specialize in developing <strong class="text-dark">unique, high-quality, and affordable products</strong> that enrich our clients' lives and reflect their personal style.
                            </p>
                            <p class="text-muted mb-5">
                                Backed by years of experience and a team of highly skilled professionals, Indigo Decors blends <strong class="text-dark">artistic vision with functional design</strong> to deliver innovative solutions that make a difference. Whether it's home decor, architectural accents, or bespoke creations, our products are made with care, creativity, and craftsmanship.
                            </p>
                            <blockquote class="editorial-quote">
                                <p>Start with creativity — understand how people live, and design to make it better.</p>
                                <footer><strong>The Indigo Decors Team</strong></footer>
                            </blockquote>
                        </div>
                    </div>
                </section>

                <!-- Workshop narrative (kept from previous version) -->
                <section class="indigo-section bg-soft">
                    <div class="container">
                        <div class="row g-5 align-items-center">
                            <div class="col-lg-6" data-indigo-fade="">
                                <div class="indigo-eyebrow">How we work</div>
                                <h2 class="h-display display-3 mb-4">More than doors.<br/><em>A signature.</em></h2>
                                <p class="lead text-muted">
                                    Every Indigo door starts as a conversation. We sit with the homeowner, the architect, or the dealer — understand the home, the style, the client. Then we design, cut, paint and install.
                                </p>
                                <p class="text-muted">
                                    Our team ships doors across Florida. Each piece is custom-quoted to the dealer's project — finish, glass, hardware and brand compatibility worked out per order, not pulled from a stock catalog.
                                </p>
                            </div>
                            <div class="col-lg-6" data-indigo-fade="" data-delay="200">
                                <div style="aspect-ratio: 4/5; border-radius: 1.5rem; overflow: hidden;">
                                    <img src="/indigo_theme/static/src/img/photo/dealer-program-hero.jpg"
                                         style="width:100%; height:100%; object-fit:cover;" alt="Our workshop"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Values / what we believe -->
                <section class="indigo-section">
                    <div class="container">
                        <div class="text-center mb-5" data-indigo-fade="">
                            <div class="indigo-eyebrow">What we believe</div>
                            <h2 class="h-display display-3">Three rules.<br/><em>No exceptions.</em></h2>
                        </div>
                        <div class="row g-4 g-lg-5">
                            <div class="col-md-4" data-indigo-fade="" data-delay="100">
                                <div style="width: 64px; height: 64px; border-radius: 9999px; background: linear-gradient(135deg, #1f4486, #3a5ea3); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: 900; margin-bottom: 1.5rem;">01</div>
                                <h3 class="h-display mb-3" style="font-size: 1.75rem;">Hand-crafted, always.</h3>
                                <p class="text-muted">Every door is shaped, finished and prepared by hand in our Miami workshop.</p>
                            </div>
                            <div class="col-md-4" data-indigo-fade="" data-delay="200">
                                <div style="width: 64px; height: 64px; border-radius: 9999px; background: linear-gradient(135deg, #1f4486, #3a5ea3); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: 900; margin-bottom: 1.5rem;">02</div>
                                <h3 class="h-display mb-3" style="font-size: 1.75rem;">Quoted to spec.</h3>
                                <p class="text-muted">No stock pricing. Every order is reviewed and quoted to the dealer's project before production.</p>
                            </div>
                            <div class="col-md-4" data-indigo-fade="" data-delay="300">
                                <div style="width: 64px; height: 64px; border-radius: 9999px; background: linear-gradient(135deg, #1f4486, #3a5ea3); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: 900; margin-bottom: 1.5rem;">03</div>
                                <h3 class="h-display mb-3" style="font-size: 1.75rem;">Tracked end-to-end.</h3>
                                <p class="text-muted">Dealers see the order status at each stage — from quote to delivery — through our portal.</p>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Workshop photos mosaic -->
                <section class="indigo-section bg-soft">
                    <div class="container">
                        <div class="mb-5" data-indigo-fade="">
                            <div class="indigo-eyebrow">Inside the workshop</div>
                            <h2 class="h-display display-3">Where it all <em>happens.</em></h2>
                        </div>
                        <div class="indigo-mosaic" data-indigo-fade="" data-delay="100">
                            <a href="#">
                                <img src="/indigo_theme/static/src/img/photo/workshop-wide-floor.jpg" alt="Workshop"/>
                            </a>
                            <a href="#">
                                <img src="/indigo_theme/static/src/img/photo/workshop-cnc-cutting.jpg" alt="Cutting"/>
                            </a>
                            <a href="#">
                                <img src="/indigo_theme/static/src/img/photo/about-hero-workshop.jpg" alt="Painting"/>
                            </a>
                            <a href="#">
                                <img src="https://images.unsplash.com/photo-1581092335397-9583eb92d232?w=500&amp;q=80" alt="QC"/>
                            </a>
                        </div>
                    </div>
                </section>

                <!-- CTA -->
                <section class="indigo-section bg-dark-gradient text-center">
                    <div class="container" style="max-width: 720px;" data-indigo-fade="">
                        <div class="indigo-eyebrow" style="color: rgba(255,255,255,0.85) !important;">Get in touch</div>
                        <h2 class="h-display display-3 mb-4 text-white">Let's build something <em>great.</em></h2>
                        <p class="lead opacity-90 mb-4">
                            Whether you're a homeowner, architect, contractor, or dealer — we'd love to hear about your project.
                        </p>
                        <div class="d-flex flex-wrap gap-3 justify-content-center">
                            <a href="/contactus" class="btn btn-light btn-lg">Contact us</a>
                            <a href="/page/dealer-program" class="btn btn-outline-light btn-lg">Become a dealer</a>
                        </div>
                    </div>
                </section>

            </div>
        </t>
    </template>

    <record id="page_about" model="website.page">
        <field name="view_id" ref="view_about"/>
        <field name="url">/page/about</field>
        <field name="is_published" eval="True"/>
    </record>

</odoo>
