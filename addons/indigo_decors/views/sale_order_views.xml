<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add Indigo per-line install context (customer, ref, address, phone,
         width, height) to the sale.order.line embedded form. Odoo 17's
         line form has no inline <notebook>, so we append a fresh group
         at the end of <form>. -->
    <record id="view_order_form_indigo_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.indigo</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/form" position="inside">
                <group string="Indigo install — for this door" name="indigo_install_group">
                    <group>
                        <field name="indigo_customer_name"/>
                        <field name="indigo_order_ref"/>
                        <field name="indigo_install_address"/>
                        <field name="indigo_install_phone" widget="phone"/>
                    </group>
                    <group>
                        <field name="indigo_door_width" string="Width (in &amp; eighths)"/>
                        <field name="indigo_door_height" string="Height (in &amp; eighths)"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
