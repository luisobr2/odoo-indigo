<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_order_label" model="ir.actions.report">
        <field name="name">Etiquetas del disenador</field>
        <field name="model">indigo.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">indigo_decors.report_order_label_doc</field>
        <field name="report_file">indigo_decors.report_order_label_doc</field>
        <field name="print_report_name">'Etiquetas %s' % (object.name or '')</field>
        <field name="binding_model_id" ref="model_indigo_order"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_indigo_label"/>
    </record>

    <template id="report_order_label_doc">
        <t t-call="web.html_container">
            <t t-set="all_labels"
               t-value="[(o, l, copy) for o in docs for l in o.line_ids for copy in range(int(l.qty or 1))]"/>
            <t t-foreach="all_labels" t-as="entry">
                <t t-set="o" t-value="entry[0]"/>
                <t t-set="l" t-value="entry[1]"/>
                <div t-attf-style="font-family: Arial, sans-serif; font-size: 4pt; line-height: 1.1; padding: 0; margin: 0; width: 55mm; height: 11mm; overflow: hidden; #{'page-break-before: always;' if not entry_first else ''}">
                    <div style="display: flex; justify-content: space-between;">
                        <span style="font-weight: bold; font-size: 4pt;" t-out="o.dealer_id.name or ''"/>
                        <span style="font-size: 4pt;" t-out="o.name or ''"/>
                    </div>
                    <div style="font-weight: bold; font-size: 5pt;" t-out="(o.client_name or '')[:24]"/>
                    <div style="font-size: 4pt;">
                        <span t-out="l.door_type or ''"/>-<span t-out="l.color or ''"/>-<span t-out="l.glass_type or ''"/>
                        <span style="float: right; font-weight: bold;" t-out="l.design_id.code or ''"/>
                    </div>
                    <div style="font-size: 4pt;">
                        <span t-out="'%.1f' % (l.width or 0)"/>x<span t-out="'%.1f' % (l.height or 0)"/>
                        <span style="float: right;">Parts:<span t-out="l.qty"/></span>
                    </div>
                </div>
            </t>
        </t>
    </template>

</odoo>
