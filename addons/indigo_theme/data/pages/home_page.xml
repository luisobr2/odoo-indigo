<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="view_home" inherit_id="website.homepage" name="Indigo Home">
        <xpath expr="//div[@id='wrap']" position="replace">
            <div id="wrap" class="oe_structure oe_empty">

                <!-- ===== HERO FULL VIEWPORT ===== -->
                <section class="indigo-hero-fullbleed">
                    <div class="hero-bg" style="background-image: url('https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=2400&amp;q=85');"/>
                    <div class="hero-overlay"/>
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-8 col-xl-7">
                                <div class="indigo-eyebrow" data-indigo-fade="">Spring 2026 · New Collection</div>
                                <h1 class="h-display" data-indigo-fade="" data-delay="100">
                                    A door that <em>tells</em><br/>your story.
                                </h1>
                                <p class="lead" data-indigo-fade="" data-delay="200">
                                    Hand-crafted, hurricane-tested high-impact doors. 142 designs, made in Miami.
                                </p>
                                <div class="d-flex flex-wrap gap-3 mt-4" data-indigo-fade="" data-delay="300">
                                    <a href="/shop" class="btn btn-light btn-lg">Shop now →</a>
                                    <a href="#categories" class="btn btn-outline-light btn-lg">Get inspired</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <a href="#categories" class="indigo-hero-scroll-indicator">
                        <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
                        </svg>
                    </a>
                </section>

                <!-- ===== CATEGORY TILES ===== -->
                <section id="categories" class="indigo-section">
                    <div class="container">
                        <div class="d-flex justify-content-between align-items-end mb-5" data-indigo-fade="">
                            <div>
                                <div class="indigo-eyebrow">Catalog</div>
                                <h2 class="h-display display-3 mb-0">Shop by category</h2>
                            </div>
                            <a href="/shop" class="text-dark text-decoration-underline fw-bold d-none d-md-inline">See everything →</a>
                        </div>
                        <div class="row g-4">
                            <div class="col-6 col-lg-3" data-indigo-fade="" data-delay="100">
                                <a href="/shop?attribute_value=53" class="indigo-tile">
                                    <div class="tile-img">
                                        <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600&amp;q=80" alt="Single doors"/>
                                    </div>
                                    <h3>Single doors</h3>
                                    <p>Quote on request · Multiple designs</p>
                                </a>
                            </div>
                            <div class="col-6 col-lg-3" data-indigo-fade="" data-delay="200">
                                <a href="/shop" class="indigo-tile">
                                    <div class="tile-img">
                                        <img src="https://images.unsplash.com/photo-1505691938895-1758d7feb511?w=600&amp;q=80" alt="Double doors"/>
                                    </div>
                                    <h3>Double doors</h3>
                                    <p>Quote on request · Multiple designs</p>
                                </a>
                            </div>
                            <div class="col-6 col-lg-3" data-indigo-fade="" data-delay="300">
                                <a href="/shop" class="indigo-tile">
                                    <div class="tile-img">
                                        <img src="https://images.unsplash.com/photo-1517472292914-9570a594783b?w=600&amp;q=80" alt="Sidelites"/>
                                    </div>
                                    <h3>Sidelites</h3>
                                    <p>Quote on request · Pair with any door</p>
                                </a>
                            </div>
                            <div class="col-6 col-lg-3" data-indigo-fade="" data-delay="400">
                                <a href="/contactus?subject=Custom%20door%20inquiry" class="indigo-tile">
                                    <div class="tile-img">
                                        <img src="https://images.unsplash.com/photo-1571939228382-b2f2b585ce15?w=600&amp;q=80" alt="Custom"/>
                                    </div>
                                    <h3>Custom design</h3>
                                    <p>Tell us your idea — we'll quote it</p>
                                </a>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ===== LIFESTYLE MOSAIC (Apple-style asymmetric) ===== -->
                <section class="indigo-section bg-soft">
                    <div class="container">
                        <div class="mb-5" data-indigo-fade="">
                            <div class="indigo-eyebrow">In real homes</div>
                            <h2 class="h-display display-3 mb-3">See it <em>installed.</em></h2>
                            <p class="lead text-muted" style="max-width: 600px;">
                                Every Indigo door becomes part of a story. Browse recent installations across Florida.
                            </p>
                        </div>
                        <div class="indigo-mosaic" data-indigo-fade="" data-delay="100">
                            <a href="/page/gallery">
                                <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=1200&amp;q=85" alt="Modern home"/>
                            </a>
                            <a href="/page/gallery">
                                <img src="https://images.unsplash.com/photo-1505691938895-1758d7feb511?w=900&amp;q=80" alt="Entrance"/>
                            </a>
                            <a href="/page/gallery">
                                <img src="https://images.unsplash.com/photo-1582268611958-ebfd161ef9cf?w=700&amp;q=80" alt="Living"/>
                            </a>
                            <a href="/page/gallery">
                                <img src="https://images.unsplash.com/photo-1567016432779-094069958ea5?w=500&amp;q=80" alt="Hallway"/>
                            </a>
                        </div>
                    </div>
                </section>

                <!-- ===== FEATURED PRODUCTS ===== -->
                <section class="indigo-section">
                    <div class="container">
                        <div class="d-flex justify-content-between align-items-end mb-5" data-indigo-fade="">
                            <div>
                                <div class="indigo-eyebrow">Featured</div>
                                <h2 class="h-display display-3 mb-0">From the catalog</h2>
                            </div>
                            <a href="/shop" class="text-dark text-decoration-underline fw-bold d-none d-md-inline">View all 142 designs →</a>
                        </div>
                        <t t-set="featured_products" t-value="request.env['product.template'].sudo().search([('is_indigo_design','=',True),('is_published','=',True)], limit=8)"/>
                        <div class="row g-4">
                            <t t-foreach="featured_products" t-as="product">
                                <div class="col-6 col-md-4 col-lg-3" data-indigo-fade="" t-att-data-delay="(product_index % 4) * 100">
                                    <a t-att-href="product.website_url" class="indigo-tile">
                                        <div class="tile-img">
                                            <img t-att-src="'/web/image/product.template/%s/image_1920' % product.id" t-att-alt="product.name"/>
                                        </div>
                                        <h3 t-out="product.name"/>
                                        <p t-out="dict(product._fields['indigo_door_type'].selection).get(product.indigo_door_type) or ''"/>
                                    </a>
                                </div>
                            </t>
                        </div>
                        <div class="text-center mt-5">
                            <a href="/shop" class="btn btn-outline-dark btn-lg">Browse all 142 designs →</a>
                        </div>
                    </div>
                </section>

                <!-- ===== HURRICANE STATS ===== -->
                <section class="indigo-section bg-dark-gradient">
                    <div class="container">
                        <div class="row align-items-center g-5">
                            <div class="col-lg-7" data-indigo-fade="">
                                <div class="indigo-eyebrow" style="color: rgba(255,255,255,0.85) !important;">Storm season</div>
                                <h2 class="h-display display-3 mb-4 text-white">
                                    Florida-ready.<br/><em>Tested.</em> Trusted.
                                </h2>
                                <p class="lead opacity-90 mb-4">
                                    Every Indigo door passes Florida HVHZ requirements. Compatible with 12 leading impact glass brands.
                                </p>
                                <a href="/shop" class="btn btn-light btn-lg">Shop hurricane-rated doors →</a>
                            </div>
                            <div class="col-lg-5" data-indigo-fade="" data-delay="200">
                                <div class="row g-4 text-center">
                                    <div class="col-4">
                                        <div class="indigo-stat-number">500+</div>
                                        <div class="small opacity-75 text-uppercase mt-2" style="letter-spacing:0.15em;">Installed</div>
                                    </div>
                                    <div class="col-4">
                                        <div class="indigo-stat-number">12</div>
                                        <div class="small opacity-75 text-uppercase mt-2" style="letter-spacing:0.15em;">Glass brands</div>
                                    </div>
                                    <div class="col-4">
                                        <div class="indigo-stat-number">10y</div>
                                        <div class="small opacity-75 text-uppercase mt-2" style="letter-spacing:0.15em;">Warranty</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ===== DEALER PROGRAM ===== -->
                <section class="indigo-section bg-dark text-white">
                    <div class="container">
                        <div class="row align-items-center g-5">
                            <div class="col-lg-7" data-indigo-fade="">
                                <div class="indigo-eyebrow text-white-50">Indigo Dealer Program</div>
                                <h2 class="h-display display-3 mb-4 text-white">
                                    For pros who<br/><em>sell at scale.</em>
                                </h2>
                                <p class="lead text-white-50 mb-4">
                                    Wholesale pricing, custom-branded materials, dedicated account manager, and full order tracking from CNC to installation.
                                </p>
                                <a href="/page/dealer-program#apply" class="btn btn-primary btn-lg me-2">Apply now</a>
                                <a href="/page/dealer-program#benefits" class="text-white text-decoration-underline">Learn about the program</a>
                            </div>
                            <div class="col-lg-5" data-indigo-fade="" data-delay="200">
                                <div style="aspect-ratio: 4/5; border-radius: 1.5rem; overflow: hidden;">
                                    <img src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=800&amp;q=80"
                                         style="width:100%; height:100%; object-fit:cover;" alt="Dealers"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ===== CERTIFICATIONS / TRUST BAND ===== -->
                <section class="indigo-section bg-soft">
                    <div class="container">
                        <div class="text-center mb-5" data-indigo-fade="">
                            <div class="indigo-eyebrow">Certifications &amp; promises</div>
                            <h2 class="h-display display-4 mb-3">Engineered for Florida.</h2>
                            <p class="lead text-muted" style="max-width: 700px; margin: 0 auto;">
                                Every Indigo door is built to the same standard — independent of who installs it.
                            </p>
                        </div>
                        <div class="row g-4 g-lg-5 text-center">
                            <div class="col-6 col-md-3" data-indigo-fade="" data-delay="100">
                                <div class="mb-3 d-inline-flex align-items-center justify-content-center"
                                     style="width:72px;height:72px;border-radius:9999px;background:rgba(31,68,134,0.08);color:#1f4486;">
                                    <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                                </div>
                                <h4 class="fw-bold mb-1" style="font-size:1.1rem;">HVHZ approved</h4>
                                <p class="small text-muted mb-0">High-Velocity Hurricane Zone certified for Miami-Dade &amp; Broward.</p>
                            </div>
                            <div class="col-6 col-md-3" data-indigo-fade="" data-delay="200">
                                <div class="mb-3 d-inline-flex align-items-center justify-content-center"
                                     style="width:72px;height:72px;border-radius:9999px;background:rgba(31,68,134,0.08);color:#1f4486;">
                                    <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
                                </div>
                                <h4 class="fw-bold mb-1" style="font-size:1.1rem;">10-year warranty</h4>
                                <p class="small text-muted mb-0">On finish, hardware and structural integrity. Every door.</p>
                            </div>
                            <div class="col-6 col-md-3" data-indigo-fade="" data-delay="300">
                                <div class="mb-3 d-inline-flex align-items-center justify-content-center"
                                     style="width:72px;height:72px;border-radius:9999px;background:rgba(31,68,134,0.08);color:#1f4486;">
                                    <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0zM12 8v4l3 3"/></svg>
                                </div>
                                <h4 class="fw-bold mb-1" style="font-size:1.1rem;">14-day promise</h4>
                                <p class="small text-muted mb-0">From order to installed — or your delivery is on us.</p>
                            </div>
                            <div class="col-6 col-md-3" data-indigo-fade="" data-delay="400">
                                <div class="mb-3 d-inline-flex align-items-center justify-content-center"
                                     style="width:72px;height:72px;border-radius:9999px;background:rgba(31,68,134,0.08);color:#1f4486;">
                                    <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                </div>
                                <h4 class="fw-bold mb-1" style="font-size:1.1rem;">Custom-quoted</h4>
                                <p class="small text-muted mb-0">Pricing per door, finish, glass &amp; SQF. No hidden line items.</p>
                            </div>
                        </div>
                    </div>
                </section>

            </div>
        </xpath>
    </template>

</odoo>
