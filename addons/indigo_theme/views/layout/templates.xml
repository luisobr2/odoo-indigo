                                    </a>
                                </div>
                            </div>

                            <!-- Shop -->
                            <div class="col-lg-2 col-md-6 col-6">
                                <h4 class="indigo-footer-heading">Shop</h4>
                                <ul class="indigo-footer-list">
                                    <li><a href="/shop">All doors</a></li>
                                    <li><a href="/shop">Single doors</a></li>
                                    <li><a href="/shop">Double doors</a></li>
                                    <li><a href="/shop">Sidelites</a></li>
                                    <li><a href="/shop">Custom orders</a></li>
                                </ul>
                            </div>

                            <!-- For Pros -->
                            <div class="col-lg-2 col-md-6 col-6">
                                <h4 class="indigo-footer-heading">For Pros</h4>
                                <ul class="indigo-footer-list">
                                    <li><a href="#">Dealer Program</a></li>
                                    <li><a href="/web/login">Dealer Login</a></li>
                                    <li><a href="#">Wholesale Pricing</a></li>
                                    <li><a href="#">Catalog Download</a></li>
