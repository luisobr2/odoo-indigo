<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="view_home" inherit_id="website.homepage" name="Indigo Home">
        <xpath expr="//div[@id='wrap']" position="replace">
            <div id="wrap" class="oe_structure oe_empty">

                <!-- ===== HERO FULL VIEWPORT ===== -->
                <section class="indigo-hero-fullbleed">
                    <div class="hero-bg" style="background-image: url('https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=2400&amp;q=85');"/>
                    <div class="hero-overlay"/>
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-8 col-xl-7">
                                <div class="indigo-eyebrow" data-indigo-fade="">Spring 2026 · New Collection</div>
                                <h1 class="h-display" data-indigo-fade="" data-delay="100">
                                    A door that <em>tells</em><br/>your story.
                                </h1>
                                <p class="lead" data-indigo-fade="" data-delay="200">
                                    Hand-crafted, hurricane-tested high-impact doors. 142 designs, made in Miami.
                                </p>
                                <div class="d-flex flex-wrap gap-3 mt-4" data-indigo-fade="" data-delay="300">
                                    <a href="/shop" class="btn btn-light btn-lg">Shop now →</a>
                                    <a href="#categories" class="btn btn-outline-light btn-lg">Get inspired</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <a href="#categories" class="indigo-hero-scroll-indicator">
                        <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
                        </svg>
                    </a>
                </section>

                <!-- ===== CATEGORY TILES ===== -->
                <section id="categories" class="indigo-section">
                    <div class="container">
                        <div class="d-flex justify-content-between align-items-end mb-5" data-indigo-fade="">
                            <div>
                                <div class="indigo-eyebrow">Catalog</div>
                                <h2 class="h-display display-3 mb-0">Shop by category</h2>
                            </div>
                            <a href="/shop" class="text-dark text-decoration-underline fw-bold d-none d-md-inline">See everything →</a>
                        </div>
                        <div class="row g-4">
                            <div class="col-6 col-lg-3" data-indigo-fade="" data-delay="100">
                                <a href="/shop" class="indigo-tile">
                                    <div class="tile-img">
                                        <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600&amp;q=80" alt="Single doors"/>
                                    </div>
                                    <h3>Single doors</h3>
                                    <p>From $1,450 · 22 designs</p>
                                </a>
                            </div>
                            <div class="col-6 col-lg-3" data-indigo-fade="" data-delay="200">
                                <a href="/shop" class="indigo-tile">
                                    <div class="tile-img">
                                        <img src="https://images.unsplash.com/photo-1505691938895-1758d7feb511?w=600&amp;q=80" alt="Double doors"/>
                                    </div>
                                    <h3>Double doors</h3>
                                    <p>From $2,250 · 7 designs</p>
                                </a>
                            </div>
                            <div class="col-6 col-lg-3" data-indigo-fade="" data-delay="300">
                                <a href="/shop" class="indigo-tile">
                                    <div class="tile-img">
                                        <img src="https://images.unsplash.com/photo-1517472292914-9570a594783b?w=600&amp;q=80" alt="Sidelites"/>
                                    </div>
                                    <h3>Sidelites</h3>
                                    <p>From $850 · 4 designs</p>
                                </a>
                            </div>
                            <div class="col-6 col-lg-3" data-indigo-fade="" data-delay="400">
                                <a href="/shop" class="indigo-tile">
                                    <div class="tile-img">
                                        <img src="https://images.unsplash.com/photo-1571939228382-b2f2b585ce15?w=600&amp;q=80" alt="Custom"/>
                                    </div>
                                    <h3>Custom design</h3>
                                    <p>Tell us your idea</p>
                                </a>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ===== LIFESTYLE MOSAIC (Apple-style asymmetric) ===== -->
                <section class="indigo-section bg-soft">
                    <div class="container">
                        <div class="mb-5" data-indigo-fade="">
                            <div class="indigo-eyebrow">In real homes</div>
                            <h2 class="h-display display-3 mb-3">See it <em>installed.</em></h2>
                            <p class="lead text-muted" style="max-width: 600px;">
                                Every Indigo door becomes part of a story. Browse recent installations across Florida.
                            </p>
                        </div>
                        <div class="indigo-mosaic" data-indigo-fade="" data-delay="100">
                            <a href="#">
                                <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=1200&amp;q=85" alt="Modern home"/>
                            </a>
                            <a href="#">
                                <img src="https://images.unsplash.com/photo-1505691938895-1758d7feb511?w=900&amp;q=80" alt="Entrance"/>
                            </a>
                            <a href="#">
                                <img src="https://images.unsplash.com/photo-1582268611958-ebfd161ef9cf?w=700&amp;q=80" alt="Living"/>
                            </a>
                            <a href="#">
                                <img src="https://images.unsplash.com/photo-1567016432779-094069958ea5?w=500&amp;q=80" alt="Hallway"/>
                            </a>
                        </div>
                    </div>
                </section>

                <!-- ===== HURRICANE STATS ===== -->
                <section class="indigo-section bg-dark-gradient">
                    <div class="container">
                        <div class="row align-items-center g-5">
                            <div class="col-lg-7" data-indigo-fade="">
                                <div class="indigo-eyebrow" style="color: rgba(255,255,255,0.85) !important;">Storm season</div>
                                <h2 class="h-display display-3 mb-4 text-white">
                                    Florida-ready.<br/><em>Tested.</em> Trusted.
                                </h2>
                                <p class="lead opacity-90 mb-4">
                                    Every Indigo door passes Florida HVHZ requirements. Compatible with 12 leading impact glass brands.
                                </p>
                                <a href="/shop" class="btn btn-light btn-lg">Shop hurricane-rated doors →</a>
                            </div>
                            <div class="col-lg-5" data-indigo-fade="" data-delay="200">
                                <div class="row g-4 text-center">
                                    <div class="col-4">
                                        <div class="indigo-stat-number">500+</div>
                                        <div class="small opacity-75 text-uppercase mt-2" style="letter-spacing:0.15em;">Installed</div>
                                    </div>
                                    <div class="col-4">
                                        <div class="indigo-stat-number">12</div>
                                        <div class="small opacity-75 text-uppercase mt-2" style="letter-spacing:0.15em;">Glass brands</div>
                                    </div>
                                    <div class="col-4">
                                        <div class="indigo-stat-number">10y</div>
                                        <div class="small opacity-75 text-uppercase mt-2" style="letter-spacing:0.15em;">Warranty</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ===== DEALER PROGRAM ===== -->
                <section class="indigo-section bg-dark text-white">
                    <div class="container">
                        <div class="row align-items-center g-5">
                            <div class="col-lg-7" data-indigo-fade="">
                                <div class="indigo-eyebrow text-white-50">Indigo Dealer Program</div>
                                <h2 class="h-display display-3 mb-4 text-white">
                                    For pros who<br/><em>sell at scale.</em>
                                </h2>
                                <p class="lead text-white-50 mb-4">
                                    Wholesale pricing, custom-branded materials, dedicated account manager, and full order tracking from CNC to installation.
                                </p>
                                <a href="#" class="btn btn-primary btn-lg me-2">Apply now</a>
                                <a href="#" class="text-white text-decoration-underline">Download brochure</a>
                            </div>
                            <div class="col-lg-5" data-indigo-fade="" data-delay="200">
                                <div style="aspect-ratio: 4/5; border-radius: 1.5rem; overflow: hidden;">
                                    <img src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=800&amp;q=80"
                                         style="width:100%; height:100%; object-fit:cover;" alt="Dealers"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ===== TESTIMONIAL ===== -->
                <section class="indigo-section bg-soft text-center">
                    <div class="container" style="max-width: 800px;" data-indigo-fade="">
                        <svg class="mb-4" width="48" height="48" viewBox="0 0 24 24" fill="#1f4486" opacity="0.4">
                            <path d="M14.017 18L20 6h-4l-3 12h1.017zM5 18l5.983-12h-4L4 18h1z"/>
                        </svg>
                        <p class="h-display" style="font-size: 2rem; font-weight: 500; line-height: 1.4;">
                            <em>"Best partner we've had.</em> Indigo's quality and tracking system have changed how we operate as a dealer."
                        </p>
                        <div class="d-flex justify-content-center align-items-center gap-3 mt-4">
                            <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold"
                                 style="width:48px; height:48px; background:#1f4486;">JD</div>
                            <div class="text-start">
                                <div class="fw-bold">John Doe</div>
                                <div class="small text-secondary">Lock Tight · Dealer since 2024</div>
                            </div>
                        </div>
                    </div>
                </section>

            </div>
        </xpath>
    </template>

</odoo>
