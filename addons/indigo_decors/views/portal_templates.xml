<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Cards on /my (portal home) for installer + dealer roles -->
    <template id="portal_my_home_installer" name="Portal home: indigo cards" inherit_id="portal.portal_my_home" priority="50">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">My installations</t>
                <t t-set="url" t-value="'/my/installs'"/>
                <t t-set="text">Orders assigned to you for measurement / installation</t>
                <t t-set="placeholder_count" t-value="'install_count'"/>
            </t>
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">My orders</t>
                <t t-set="url" t-value="'/my/orders'"/>
                <t t-set="text">Track, duplicate or upload payment for your dealer orders</t>
                <t t-set="placeholder_count" t-value="'order_count'"/>
            </t>
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">New order</t>
                <t t-set="url" t-value="'/my/order/new'"/>
                <t t-set="text">Place a new order directly — pre-fills past homeowners</t>
            </t>
        </xpath>
    </template>

    <!-- Installer's assigned orders list -->
    <template id="portal_installer_orders" name="My installations">
        <t t-call="portal.portal_layout">
            <t t-set="page_name" t-value="'installer_orders'"/>
            <div class="o_portal_my_home">
                <h3 class="mb-3" style="color:#1f4486;">My installations</h3>
                <t t-if="not orders">
                    <p class="text-muted">No orders assigned to you yet.</p>
                </t>
                <table t-if="orders" class="table table-hover">
                    <thead style="background-color:#1f4486; color:#fff;">
                        <tr>
                            <th>Order</th>
                            <th>Dealer</th>
                            <th>Customer</th>
                            <th>Address</th>
                            <th class="text-end">Doors</th>
                            <th>Stage</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="orders" t-as="o">
                            <td>
                                <a t-attf-href="/my/install/#{o.id}" t-out="o.name"/>
                            </td>
                            <td t-out="o.dealer_id.name or ''"/>
                            <td t-out="o.client_name or ''"/>
                            <td t-out="o.client_address or ''"/>
                            <td class="text-end" t-out="o.door_count"/>
                            <td>
                                <span class="indigo-stage-badge" t-out="o.stage_id.name or ''"/>
                                <span t-if="o.on_hold" class="badge text-bg-warning ms-1">On hold</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </t>
    </template>

    <!-- =========================
         PORTAL DEALER
         ========================= -->

    <template id="portal_dealer_orders" name="My orders (dealer)">
        <t t-call="portal.portal_layout">
            <t t-set="page_name" t-value="'dealer_orders'"/>
            <div class="o_portal_my_home">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3 style="color:#1f4486; margin:0;">My orders</h3>
                    <a href="/my/order/new" class="btn btn-sm btn-primary" style="background-color:#1f4486; border-color:#1f4486;">
                        <span aria-hidden="true">+</span> New order
                    </a>
                </div>
                <t t-if="not orders">
                    <p class="text-muted">No orders yet. Create your first one with the button above.</p>
                </t>
                <table t-if="orders" class="table table-hover indigo-portal-table">
                    <thead style="background-color:#1f4486; color:#fff;">
                        <tr>
                            <th>Order</th>
                            <th>Customer</th>
                            <th>Dealer ref</th>
                            <th class="text-end">Doors</th>
                            <th class="text-end">SQF</th>
                            <th>Stage</th>
                            <th>Payment</th>
                            <th class="text-end" style="width: 1%; white-space: nowrap;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="orders" t-as="o">
                            <td>
                                <a t-attf-href="/my/order/#{o.id}" t-out="o.name"/>
                            </td>
                            <td t-out="o.client_name or ''"/>
                            <td t-out="o.dealer_ref or ''"/>
                            <td class="text-end" t-out="o.door_count"/>
                            <td class="text-end" t-out="'%.2f' % (o.total_sqf or 0)"/>
                            <td>
                                <span class="indigo-stage-badge" t-out="o.stage_id.name or ''"/>
                                <span t-if="o.on_hold" class="badge text-bg-warning ms-1">On hold</span>
                            </td>
                            <td>
                                <span class="indigo-payment-badge"
                                      t-att-data-state="o.payment_state or 'unpaid'"
                                      t-out="(o.payment_state or 'unpaid').replace('_',' ').title()"/>
                            </td>
                            <td class="text-end">
                                <form t-attf-action="/my/order/#{o.id}/duplicate" method="post" class="d-inline">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <button type="submit" class="btn btn-sm btn-outline-primary"
                                            title="Duplicate this order — copies customer, address, pieces and dimensions. You only edit what's different.">
                                        <span aria-hidden="true">&#x2398;</span> Duplicate
                                    </button>
                                </form>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </t>
    </template>

    <template id="portal_dealer_order_detail" name="Order detail (dealer)">
        <t t-call="portal.portal_layout">
            <t t-set="page_name" t-value="'dealer_order_detail'"/>
            <div class="o_portal_my_home">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3 style="color:#1f4486; margin:0;">Order <span t-out="order.name"/></h3>
                    <a href="/my/orders" class="btn btn-sm btn-outline-secondary">&#x2190; Back to orders</a>
                </div>

                <div class="card mb-3">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <strong>Customer:</strong> <span t-out="order.client_name or '—'"/><br/>
                                <strong>Phone:</strong> <span t-out="order.client_phone or '—'"/><br/>
                                <strong>Email:</strong> <span t-out="order.client_email or '—'"/>
                            </div>
                            <div class="col-md-6">
                                <strong>Address:</strong>
                                <div style="white-space: pre-wrap;" t-out="order.client_address or '—'"/>
                                <strong>Your ref:</strong> <span t-out="order.dealer_ref or '—'"/>
                            </div>
                        </div>
                        <hr/>
                        <strong>Current stage:</strong>
                        <span class="indigo-stage-badge" t-out="order.stage_id.name or ''"/>
                        <span class="ms-3"><strong>Total doors:</strong> <span t-out="order.door_count"/></span>
                        <span class="ms-3"><strong>Total SQF:</strong> <span t-out="'%.2f' % (order.total_sqf or 0)"/></span>
                        <span class="ms-3"><strong>Estimated total:</strong> $<span t-out="'%.2f' % (order.total_dealer_charge or 0)"/></span>
                    </div>
                </div>

                <h4>Pieces</h4>
                <table class="table table-sm indigo-portal-table">
                    <thead style="background-color:#f5f7fb;">
                        <tr>
                            <th>#</th><th>Design</th><th>Type</th><th>Color</th><th>Glass</th>
                            <th>Measurements</th><th>Qty</th><th class="text-end">SQF</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="order.line_ids" t-as="l">
                            <td t-out="l_index + 1"/>
                            <td t-out="l.design_id.code or '—'"/>
                            <td t-out="l.door_type or ''"/>
                            <td t-out="l.color or ''"/>
                            <td t-out="l.glass_type or ''"/>
                            <td><span t-out="l.width_label or l.width"/> &#215; <span t-out="l.height_label or l.height"/> in</td>
                            <td t-out="l.qty"/>
                            <td class="text-end" t-out="'%.2f' % (l.sqf or 0)"/>
                        </tr>
                    </tbody>
                </table>

                <h4 class="mt-4">Quick actions</h4>
                <div class="d-flex gap-2 flex-wrap mb-4">
                    <form t-attf-action="/my/order/#{order.id}/duplicate" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <button type="submit" class="btn btn-outline-primary btn-sm">
                            <span aria-hidden="true">&#x2398;</span> Duplicate this order
                        </button>
                    </form>
                </div>

                <h4 class="mt-4">Upload payment receipt</h4>
                <form t-attf-action="/my/order/#{order.id}/upload-receipt" method="post" enctype="multipart/form-data" class="card card-body">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <input type="file" name="receipt" class="form-control mb-2" accept="image/*,application/pdf" required="required"/>
                    <button class="btn btn-primary btn-sm" style="background-color:#1f4486; border-color:#1f4486;">Upload receipt</button>
                </form>
            </div>
        </t>
    </template>

    <!-- Tracking publico (sin login) -->
    <template id="portal_public_tracking_not_found" name="Tracking publico - no encontrado">
        <t t-call="web.frontend_layout">
            <div class="container py-5 text-center">
                <h2 style="color:#1f4486;">Orden no encontrada</h2>
                <p class="text-muted">El enlace puede haber expirado o no existir. Contacte al dealer que le envio este link.</p>
            </div>
        </t>
    </template>

    <template id="portal_public_tracking" name="Tracking publico de orden">
        <t t-call="web.frontend_layout">
            <div class="container py-4" style="max-width: 760px;">
                <h2 style="color:#1f4486;">Estado de su pedido</h2>
                <p class="text-muted">Orden <strong t-out="order.name"/> - Indigo Decors</p>

                <div class="card mb-3">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <strong>Cliente:</strong> <span t-out="order.client_name or ''"/>
                            </div>
                            <div class="col-md-6 text-end">
                                <strong>Total puertas:</strong> <span t-out="order.door_count"/>
                            </div>
                        </div>
                    </div>
                </div>

                <h4>Progreso</h4>
                <div class="card mb-3">
                    <div class="card-body">
                        <div style="font-size: 18px;">
                            <strong>Etapa actual:</strong>
                            <span class="badge text-bg-info" t-out="order.stage_id.name or ''"/>
                            <t t-if="order.on_hold">
                                <span class="badge text-bg-warning ms-2">En espera</span>
                            </t>
                        </div>
                        <div t-if="order.installation_date" class="mt-2">
                            <strong>Instalacion programada:</strong>
                            <span t-out="order.installation_date"/>
                        </div>
                        <div t-if="order.expected_completion_date" class="mt-2">
                            <strong>Fecha estimada de entrega:</strong>
                            <span t-out="order.expected_completion_date"/>
                        </div>
                    </div>
                </div>

                <h4>Piezas</h4>
                <table class="table table-sm">
                    <thead style="background-color:#1f4486; color:#fff;">
                        <tr><th>#</th><th>Diseno</th><th>Tipo</th><th>Color</th><th>Medidas</th><th>Cant.</th></tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="order.line_ids" t-as="l">
                            <td t-out="l_index + 1"/>
                            <td t-out="l.design_id.code or ''"/>
                            <td t-out="l.door_type or ''"/>
                            <td t-out="l.color or ''"/>
                            <td><span t-out="l.width"/> x <span t-out="l.height"/></td>
                            <td t-out="l.qty"/>
                        </tr>
                    </tbody>
                </table>

                <p class="text-muted small mt-4">
                    Esta pagina se actualiza automaticamente cuando avanza el pedido.
                </p>
            </div>
        </t>
    </template>

    <template id="portal_dealer_order_new" name="New order (dealer)">
        <t t-call="portal.portal_layout">
            <t t-set="page_name" t-value="'dealer_order_new'"/>
            <div class="o_portal_my_home">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3 style="color:#1f4486; margin:0;">New order</h3>
                    <a href="/my/orders" class="btn btn-sm btn-outline-secondary">&#x2190; Back to orders</a>
                </div>
                <form action="/my/order/new" method="post" class="card card-body">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <h5>End customer
                        <small class="text-muted" style="font-weight: normal;">
                            — start typing a name; if you've ordered for them before, address and phone autofill
                        </small>
                    </h5>
                    <div class="row g-2 mb-3">
                        <div class="col-md-6"><label>Customer name *</label>
                            <input class="form-control" name="client_name" id="indigo-client-name"
                                   list="indigo-customers-list" autocomplete="off" required="required"
                                   placeholder="Andrea Vargas, Patricia Morales..."/>
                            <datalist id="indigo-customers-list"></datalist>
                        </div>
                        <div class="col-md-3"><label>Phone</label>
                            <input class="form-control" name="client_phone" id="indigo-client-phone"/>
                        </div>
                        <div class="col-md-3"><label>Email</label>
                            <input class="form-control" name="client_email" id="indigo-client-email" type="email"/>
                        </div>
                        <div class="col-md-12"><label>Install address</label>
                            <textarea class="form-control" name="client_address" id="indigo-client-address" rows="2"
                                      placeholder="Street, City, State ZIP"></textarea>
                        </div>
                        <div class="col-md-6"><label>Your reference (dealer ref)</label>
                            <input class="form-control" name="dealer_ref" placeholder="e.g. JOB-2026-014"/>
                        </div>
                        <div class="col-md-6"><label>Internal reference (PRIV)
                            <small class="text-muted">— optional private code printed on the door label</small>
                        </label>
                            <input class="form-control" name="priv_ref"/>
                        </div>
                    </div>

                    <h5>Pieces</h5>
                    <table class="table table-sm indigo-portal-table" id="lines-table">
                        <thead>
                            <tr>
                                <th style="width: 22%;">Design (code)</th>
                                <th>Type</th><th>Color</th><th>Glass</th>
                                <th>Width</th><th>Height</th><th>Qty</th><th></th>
                            </tr>
                        </thead>
                        <tbody id="lines-body">
                            <tr class="line-row" data-index="1">
                                <td>
                                    <input list="designs-list" name="line_design_1" class="form-control form-control-sm" placeholder="ID01-DD"/>
                                </td>
                                <td>
                                    <select name="line_door_type_1" class="form-select form-select-sm">
                                        <option value="SD">SD</option>
                                        <option value="DD">DD</option>
                                        <option value="sidelite">Sidelite</option>
                                    </select>
                                </td>
                                <td>
                                    <select name="line_color_1" class="form-select form-select-sm">
                                        <option value="white">White</option>
                                        <option value="bronze">Bronze</option>
                                        <option value="black">Black</option>
                                        <option value="custom">Custom</option>
                                    </select>
                                </td>
                                <td><input name="line_glass_1" class="form-control form-control-sm" placeholder="ESW"/></td>
                                <td>
                                    <div class="input-group input-group-sm" style="width: 110px;">
                                        <input name="line_width_1" type="text" pattern="[0-9 /.]+"
                                               class="form-control form-control-sm" placeholder="36 1/8"
                                               title="Inches and eighths: 36 or 36 1/8"/>
                                        <span class="input-group-text">in</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="input-group input-group-sm" style="width: 110px;">
                                        <input name="line_height_1" type="text" pattern="[0-9 /.]+"
                                               class="form-control form-control-sm" placeholder="83 3/4"
                                               title="Inches and eighths: 80 or 96 4/8"/>
                                        <span class="input-group-text">in</span>
                                    </div>
                                </td>
                                <td><input name="line_qty_1" type="number" value="1" min="1" class="form-control form-control-sm" style="width: 60px;"/></td>
                                <td><button type="button" class="btn btn-sm btn-outline-danger remove-line" title="Remove row">&#x2715;</button></td>
                            </tr>
                        </tbody>
                    </table>
                    <datalist id="designs-list">
                        <option t-foreach="designs" t-as="d" t-att-value="d.code">
                            <t t-out="d.name or d.code"/>
                        </option>
                    </datalist>
                    <div class="mb-3">
                        <button type="button" id="add-line" class="btn btn-sm btn-outline-primary">
                            <span aria-hidden="true">+</span> Add another piece
                        </button>
                        <span class="text-muted ms-2 small">— format inches and eighths, e.g. <code>36 1/8</code> or <code>80</code></span>
                    </div>

                    <label>Additional notes</label>
                    <textarea class="form-control mb-3" name="notes" rows="2"
                              placeholder="Anything sales should know — special requests, deadlines, install caveats..."></textarea>

                    <div>
                        <button type="submit" class="btn btn-primary" style="background-color:#1f4486; border-color:#1f4486;">
                            Create order
                        </button>
                        <a href="/my/orders" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>

                <script type="text/javascript">
                document.addEventListener('DOMContentLoaded', function() {
                    // ----- Multi-line piezas -----
                    var idx = 1;
                    document.getElementById('add-line').addEventListener('click', function() {
                        idx += 1;
                        var tbody = document.getElementById('lines-body');
                        var firstRow = tbody.querySelector('.line-row');
                        var clone = firstRow.cloneNode(true);
                        clone.setAttribute('data-index', idx);
                        clone.querySelectorAll('input, select').forEach(function(el) {
                            var name = el.name.replace(/_\d+$/, '_' + idx);
                            el.name = name;
                            if (el.type !== 'number' || el.name.indexOf('_qty_') === -1) el.value = el.defaultValue || '';
                        });
                        tbody.appendChild(clone);
                    });
                    document.getElementById('lines-body').addEventListener('click', function(e) {
                        if (e.target.classList.contains('remove-line')) {
                            var rows = document.querySelectorAll('.line-row');
                            if (rows.length &gt; 1) {
                                e.target.closest('tr').remove();
                            }
                        }
                    });

                    // ----- Libreta de homeowners (autocomplete + auto-fill) -----
                    var nameInput = document.getElementById('indigo-client-name');
                    var phoneInput = document.getElementById('indigo-client-phone');
                    var emailInput = document.getElementById('indigo-client-email');
                    var addrInput = document.getElementById('indigo-client-address');
                    var datalist = document.getElementById('indigo-customers-list');
                    if (!nameInput || !datalist) return;

                    var allCustomers = [];   // last fetch results
                    var lastQuery = null;
                    var fetchTimer = null;

                    function renderOptions(items) {
                        datalist.innerHTML = '';
                        items.forEach(function(c) {
                            var opt = document.createElement('option');
                            opt.value = c.name;
                            // Show phone as a hint in the dropdown
                            opt.label = c.phone ? (c.name + ' — ' + c.phone) : c.name;
                            datalist.appendChild(opt);
                        });
                    }

                    function fetchCustomers(q) {
                        if (q === lastQuery) return;
                        lastQuery = q;
                        fetch('/my/order/customers.json?q=' + encodeURIComponent(q || ''))
                            .then(function(r) { return r.json(); })
                            .then(function(items) {
                                allCustomers = items || [];
                                renderOptions(allCustomers);
                            })
                            .catch(function() { /* silent */ });
                    }

                    // Initial fetch (top 20 most recent) on focus
                    nameInput.addEventListener('focus', function() {
                        if (allCustomers.length === 0) fetchCustomers('');
                    });

                    // Debounced refetch as user types
                    nameInput.addEventListener('input', function() {
                        var q = nameInput.value.trim();
                        clearTimeout(fetchTimer);
                        fetchTimer = setTimeout(function() { fetchCustomers(q); }, 250);

                        // Auto-fill if exact match found in current cache
                        var match = allCustomers.find(function(c) {
                            return c.name.toLowerCase() === q.toLowerCase();
                        });
                        if (match) {
                            if (!phoneInput.value) phoneInput.value = match.phone || '';
                            if (!emailInput.value) emailInput.value = match.email || '';
                            if (!addrInput.value) addrInput.value = match.address || '';
                        }
                    });
                });
                </script>
            </div>
        </t>
    </template>

    <!-- Detalle: datos + piezas + subir foto + marcar instalada -->
    <template id="portal_installer_order_detail" name="Detalle de instalacion">
        <t t-call="portal.portal_layout">
            <t t-set="page_name" t-value="'installer_order_detail'"/>
            <div class="o_portal_my_home">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3 style="color:#1f4486; margin:0;">
                        Orden <span t-out="order.name"/>
                    </h3>
                    <a href="/my/installs" class="btn btn-sm btn-secondary">&#x2190; Volver</a>
                </div>

                <div class="card mb-3">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <strong>Dealer:</strong> <span t-out="order.dealer_id.name or ''"/><br/>
                                <strong>Cliente:</strong> <span t-out="order.client_name or ''"/><br/>
                                <strong>Telefono:</strong> <span t-out="order.client_phone or ''"/>
                            </div>
                            <div class="col-md-6">
                                <strong>Direccion:</strong>
                                <div style="white-space: pre-wrap;" t-out="order.client_address or ''"/>
                            </div>
                        </div>
                        <hr/>
                        <div>
                            <strong>Etapa actual:</strong>
                            <span class="badge text-bg-info" t-out="order.stage_id.name or ''"/>
                            <span class="ms-3">
                                <strong>Total puertas:</strong> <span t-out="order.door_count"/>
                            </span>
                        </div>
                    </div>
                </div>

                <h4>Piezas a instalar</h4>
                <table class="table table-sm">
                    <thead style="background-color:#f5f7fb;">
                        <tr>
                            <th>#</th>
                            <th>Diseno</th>
                            <th>Tipo</th>
                            <th>Color</th>
                            <th>Medidas</th>
                            <th>Cantidad</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="order.line_ids" t-as="l">
                            <td t-out="l_index + 1"/>
                            <td t-out="l.design_id.code or ''"/>
                            <td t-out="l.door_type or ''"/>
                            <td t-out="l.color or ''"/>
                            <td>
                                <span t-out="l.width"/>x<span t-out="l.height"/>
                            </td>
                            <td t-out="l.qty"/>
                        </tr>
                    </tbody>
                </table>

                <h4 class="mt-4">Subir foto del trabajo</h4>
                <form t-attf-action="/my/install/#{order.id}/upload" method="post" enctype="multipart/form-data" class="card card-body">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <div class="mb-2">
                        <input type="file" name="photo" class="form-control" accept="image/*" required="required"/>
                    </div>
                    <div class="mb-2">
                        <input type="text" name="note" placeholder="Nota (opcional)" class="form-control"/>
                    </div>
                    <button class="btn btn-primary" type="submit" style="background-color:#1f4486; border-color:#1f4486;">
                        Subir foto
                    </button>
                </form>

                <t t-if="order.stage_id.code != 'installed'">
                    <h4 class="mt-4">Marcar como instalada</h4>
                    <form t-attf-action="/my/install/#{order.id}/mark-installed" method="post" class="card card-body" onsubmit="return indigoCaptureSignature(this)">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="signature_data" id="signature_data"/>
                        <p class="mb-2 text-muted">
                            Pidale al cliente que firme abajo. Al confirmar, la orden pasa
                            a etapa <strong>Installed</strong> y se genera tu liquidacion.
                        </p>
                        <div class="mb-2">
                            <label>Nombre del firmante</label>
                            <input class="form-control" name="signer_name" t-att-value="order.client_name or ''"/>
                        </div>
                        <label class="mb-1">Firma del cliente</label>
                        <canvas id="sigCanvas" width="500" height="180"
                                style="border: 1px solid #ccc; background: #fff; touch-action: none; width: 100%; max-width: 500px;"/>
                        <div class="d-flex gap-2 mt-2 mb-3">
                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="indigoClearSig()">Borrar firma</button>
                        </div>
                        <button class="btn btn-success" type="submit">Confirmar instalacion completada</button>
                    </form>
                    <script type="text/javascript">
                    (function() {
                        var canvas = document.getElementById('sigCanvas');
                        if (!canvas) return;
                        var ctx = canvas.getContext('2d');
                        ctx.lineWidth = 2; ctx.strokeStyle = '#1f4486'; ctx.lineCap = 'round';
                        var drawing = false, lastX = 0, lastY = 0, hasInk = false;
                        function getPos(e) {
                            var r = canvas.getBoundingClientRect();
                            var t = e.touches &amp;&amp; e.touches[0];
                            var x = (t ? t.clientX : e.clientX) - r.left;
                            var y = (t ? t.clientY : e.clientY) - r.top;
                            return {x: x * (canvas.width / r.width), y: y * (canvas.height / r.height)};
                        }
                        function start(e) { drawing = true; var p = getPos(e); lastX = p.x; lastY = p.y; e.preventDefault(); }
                        function move(e) {
                            if (!drawing) return;
                            var p = getPos(e);
                            ctx.beginPath(); ctx.moveTo(lastX, lastY); ctx.lineTo(p.x, p.y); ctx.stroke();
                            lastX = p.x; lastY = p.y; hasInk = true;
                            e.preventDefault();
                        }
                        function end(e) { drawing = false; }
                        canvas.addEventListener('mousedown', start);
                        canvas.addEventListener('mousemove', move);
                        canvas.addEventListener('mouseup', end);
                        canvas.addEventListener('mouseout', end);
                        canvas.addEventListener('touchstart', start);
                        canvas.addEventListener('touchmove', move);
                        canvas.addEventListener('touchend', end);
                        window.indigoClearSig = function() {
                            ctx.clearRect(0, 0, canvas.width, canvas.height);
                            hasInk = false;
                        };
                        window.indigoCaptureSignature = function(form) {
                            if (hasInk) {
                                form.signature_data.value = canvas.toDataURL('image/png');
                            }
                            return true;
                        };
                    })();
                    </script>
                </t>
            </div>
        </t>
    </template>

</odoo>
