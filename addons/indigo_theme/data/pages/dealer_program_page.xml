<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Pagina Dealer Program -->
    <template id="view_dealer_program" name="Dealer Program">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">

                <!-- Hero -->
                <section class="indigo-hero-fullbleed">
                    <div class="hero-bg" style="background-image: url('/indigo_theme/static/src/img/photo/dealer-program-hero.jpg');"/>
                    <div class="hero-overlay"/>
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-8">
                                <div class="indigo-eyebrow" style="color: rgba(255,255,255,0.85) !important;">Indigo Dealer Program</div>
                                <h1 class="h-display">For pros who <em>sell at scale.</em></h1>
                                <p class="lead">Become an Indigo dealer. Dealer pricing, co-branded materials and full order tracking from quote to delivery.</p>
                                <div class="d-flex flex-column flex-sm-row flex-wrap gap-3 gap-md-4 mt-5">
                                    <a href="#apply" class="btn btn-light btn-lg w-100 w-sm-auto">Apply now →</a>
                                    <a href="#benefits" class="btn btn-outline-light btn-lg w-100 w-sm-auto">Learn more</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Benefits grid -->
                <section id="benefits" class="indigo-section">
                    <div class="container">
                        <div class="text-center mb-5" data-indigo-fade="">
                            <div class="indigo-eyebrow">Why Indigo</div>
                            <h2 class="h-display display-3 mb-3">Built for distributors.</h2>
                            <p class="lead text-muted" style="max-width: 700px; margin: 0 auto;">
                                Everything you need to grow your decorative-door business in Florida.
                            </p>
                        </div>
                        <div class="row g-4 g-lg-5">
                            <div class="col-md-6 col-lg-4" data-indigo-fade="" data-delay="100">
                                <div class="indigo-benefit-card">
                                    <div class="indigo-benefit-icon">
                                        <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                                    </div>
                                    <h3>Dealer pricing</h3>
                                    <p>Tier-based pricing reviewed per dealer relationship and project volume.</p>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-4" data-indigo-fade="" data-delay="200">
                                <div class="indigo-benefit-card">
                                    <div class="indigo-benefit-icon">
                                        <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="3" y1="20" x2="21" y2="20"/></svg>
                                    </div>
                                    <h3>Real-time tracking</h3>
                                    <p>Order dashboard from quote to delivery — every stage logged in the dealer portal.</p>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-4" data-indigo-fade="" data-delay="300">
                                <div class="indigo-benefit-card">
                                    <div class="indigo-benefit-icon">
                                        <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
                                    </div>
                                    <h3>Co-branded materials</h3>
                                    <p>Brochures, samples and showroom displays with your logo.</p>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-4" data-indigo-fade="" data-delay="100">
                                <div class="indigo-benefit-card">
                                    <div class="indigo-benefit-icon">
                                        <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                    </div>
                                    <h3>Lead time on quote</h3>
                                    <p>Each quote includes a confirmed production lead time before you commit the order.</p>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-4" data-indigo-fade="" data-delay="200">
                                <div class="indigo-benefit-card">
                                    <div class="indigo-benefit-icon">
                                        <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
                                    </div>
                                    <h3>Made in Miami</h3>
                                    <p>Doors are cut, finished and quality-checked in our own workshop — no white-label intermediaries.</p>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-4" data-indigo-fade="" data-delay="300">
                                <div class="indigo-benefit-card">
                                    <div class="indigo-benefit-icon">
                                        <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
                                    </div>
                                    <h3>Account manager</h3>
                                    <p>Direct line to a dedicated person who knows your account and projects.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Apply form -->
                <section id="apply" class="indigo-section bg-soft">
                    <div class="container">
                        <div class="row g-5 align-items-center">
                            <div class="col-lg-5" data-indigo-fade="">
                                <div class="indigo-eyebrow">Get started</div>
                                <h2 class="h-display display-4 mb-3">Apply to become a dealer.</h2>
                                <p class="lead text-muted mb-4">
                                    Tell us about your business. We respond within 48 business hours.
                                </p>
                                <ul class="list-unstyled">
                                    <li class="mb-2">✓ Active business license required</li>
                                    <li class="mb-2">✓ Florida-based or able to install in FL</li>
                                    <li class="mb-2">✓ Showroom or design studio preferred</li>
                                </ul>
                            </div>
                            <div class="col-lg-7" data-indigo-fade="" data-delay="200">
                                <div class="card border-0 shadow-lg p-4 p-md-5" style="border-radius: 1.5rem;">
                                    <form action="/website/form/mail.mail" method="post" enctype="multipart/form-data" data-mark="Dealer Program Application">
                                        <input type="hidden" name="email_to" value="sales@indigodecors.com"/>
                                        <input type="hidden" name="subject" value="New Dealer Program Application"/>
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label small fw-bold">Company name *</label>
                                                <input class="form-control" name="company_name" required="required"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small fw-bold">Contact person *</label>
                                                <input class="form-control" name="contact_name" required="required"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small fw-bold">Email *</label>
                                                <input type="email" class="form-control" name="email_from" required="required"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small fw-bold">Phone *</label>
                                                <input class="form-control" name="phone" required="required" placeholder="+1 305 555 0000"/>
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label small fw-bold">Address 1 *</label>
                                                <input class="form-control" name="address_1" required="required" placeholder="Street address"/>
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label small fw-bold">Address 2</label>
                                                <input class="form-control" name="address_2" placeholder="Suite or Unit #"/>
                                            </div>
                                            <div class="col-md-5">
                                                <label class="form-label small fw-bold">City *</label>
                                                <input class="form-control" name="city" required="required"/>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small fw-bold">State *</label>
                                                <select class="form-control" name="state" required="required">
                                                    <option value="">— Select —</option>
                                                    <option>Alabama (AL)</option><option>Alaska (AK)</option>
                                                    <option>Arizona (AZ)</option><option>Arkansas (AR)</option>
                                                    <option>California (CA)</option><option>Colorado (CO)</option>
                                                    <option>Connecticut (CT)</option><option>Delaware (DE)</option>
                                                    <option selected="selected">Florida (FL)</option>
                                                    <option>Georgia (GA)</option><option>Hawaii (HI)</option>
                                                    <option>Idaho (ID)</option><option>Illinois (IL)</option>
                                                    <option>Indiana (IN)</option><option>Iowa (IA)</option>
                                                    <option>Kansas (KS)</option><option>Kentucky (KY)</option>
                                                    <option>Louisiana (LA)</option><option>Maine (ME)</option>
                                                    <option>Maryland (MD)</option><option>Massachusetts (MA)</option>
                                                    <option>Michigan (MI)</option><option>Minnesota (MN)</option>
                                                    <option>Mississippi (MS)</option><option>Missouri (MO)</option>
                                                    <option>Montana (MT)</option><option>Nebraska (NE)</option>
                                                    <option>Nevada (NV)</option><option>New Hampshire (NH)</option>
                                                    <option>New Jersey (NJ)</option><option>New Mexico (NM)</option>
                                                    <option>New York (NY)</option><option>North Carolina (NC)</option>
                                                    <option>North Dakota (ND)</option><option>Ohio (OH)</option>
                                                    <option>Oklahoma (OK)</option><option>Oregon (OR)</option>
                                                    <option>Pennsylvania (PA)</option><option>Rhode Island (RI)</option>
                                                    <option>South Carolina (SC)</option><option>South Dakota (SD)</option>
                                                    <option>Tennessee (TN)</option><option>Texas (TX)</option>
                                                    <option>Utah (UT)</option><option>Vermont (VT)</option>
                                                    <option>Virginia (VA)</option><option>Washington (WA)</option>
                                                    <option>West Virginia (WV)</option><option>Wisconsin (WI)</option>
                                                    <option>Wyoming (WY)</option>
                                                </select>
                                            </div>
                                            <div class="col-md-3">
                                                <label class="form-label small fw-bold">Zip Code *</label>
                                                <input class="form-control" name="zip" required="required" placeholder="33142"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small fw-bold">Years in business</label>
                                                <select class="form-control" name="years">
                                                    <option>Less than 1 year</option>
                                                    <option>1-3 years</option>
                                                    <option>3-10 years</option>
                                                    <option>10+ years</option>
                                                </select>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small fw-bold">Company's logo</label>
                                                <input type="file" class="form-control" name="company_logo" accept="image/*"/>
                                                <small class="text-muted">For co-branded materials. PNG / JPG / SVG.</small>
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label small fw-bold">Tell us about your business *</label>
                                                <textarea class="form-control" name="description" rows="4" required="required" placeholder="Kind of projects you do, expected volume, showroom?, current door brands you carry, etc."></textarea>
                                            </div>
                                            <div class="col-12">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" name="terms_agreed" id="terms_agreed" value="yes" required="required"/>
                                                    <label class="form-check-label small" for="terms_agreed">
                                                        I agree to the <a href="/page/dealer-program#terms">Dealer Program Terms &amp; Conditions</a> *
                                                    </label>
                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <button type="submit" class="btn btn-primary btn-lg w-100">Submit application →</button>
                                                <p class="small text-muted mt-2 mb-0 text-center">We respond within 48 business hours. Your information is reviewed by our team only.</p>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

            </div>
        </t>
    </template>

    <record id="page_dealer_program" model="website.page">
        <field name="view_id" ref="view_dealer_program"/>
        <field name="url">/page/dealer-program</field>
        <field name="is_published" eval="True"/>
    </record>

</odoo>
