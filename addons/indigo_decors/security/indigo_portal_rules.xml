<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="rule_indigo_order_portal_installer" model="ir.rule">
            <field name="name">Indigo Order: portal installer ve solo sus ordenes</field>
            <field name="model_id" ref="model_indigo_order"/>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="domain_force">[('installer_ids.user_ids', 'in', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_indigo_order_line_portal_installer" model="ir.rule">
            <field name="name">Indigo Order Line: portal installer ve solo lineas de sus ordenes</field>
            <field name="model_id" ref="model_indigo_order_line"/>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="domain_force">[('order_id.installer_ids.user_ids', 'in', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Dealer portal: ve solo sus propias ordenes (donde dealer_id = su partner). -->
        <!-- Se UNE OR con la regla del instalador via record rules (varios rules del mismo grupo = OR). -->
        <record id="rule_indigo_order_portal_dealer" model="ir.rule">
            <field name="name">Indigo Order: portal dealer ve sus propias ordenes</field>
            <field name="model_id" ref="model_indigo_order"/>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="domain_force">[('dealer_id', '=', user.partner_id.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_indigo_order_line_portal_dealer" model="ir.rule">
            <field name="name">Indigo Order Line: portal dealer ve sus propias lineas</field>
            <field name="model_id" ref="model_indigo_order_line"/>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="domain_force">[('order_id.dealer_id', '=', user.partner_id.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
