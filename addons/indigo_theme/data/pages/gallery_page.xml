<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="view_gallery" name="Gallery / Inspiration">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">

                <!-- Hero -->
                <section class="indigo-hero-fullbleed" style="min-height: 50vh;">
                    <div class="hero-bg" style="background-image: url('/indigo_theme/static/src/img/photo/home-hero-miami-door.jpg');"/>
                    <div class="hero-overlay"/>
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-9 col-xl-8">
                                <div class="indigo-eyebrow" style="color: rgba(255,255,255,0.85) !important;">Inspiration</div>
                                <h1 class="h-display">Doors in the <em>wild.</em></h1>
                                <p class="lead">Real installations across Florida. Browse projects from the dealer network.</p>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Filter pills — compact sticky bar -->
                <section class="indigo-gallery-filters sticky-top">
                    <div class="container">
                        <div class="indigo-gallery-filters__row" data-indigo-fade="">
                            <button class="indigo-chip is-active" data-indigo-filter="all">All</button>
                            <button class="indigo-chip" data-indigo-filter="single">Single</button>
                            <button class="indigo-chip" data-indigo-filter="double">Double</button>
                            <button class="indigo-chip" data-indigo-filter="sidelite">Sidelites</button>
                            <button class="indigo-chip" data-indigo-filter="custom">Custom</button>
                            <span class="indigo-chip-divider"/>
                            <button class="indigo-chip" data-indigo-filter="black">Black</button>
                            <button class="indigo-chip" data-indigo-filter="white">White</button>
                            <button class="indigo-chip" data-indigo-filter="bronze">Bronze</button>
                        </div>
                    </div>
                </section>

                <!-- Masonry-style grid -->
                <section class="indigo-section">
                    <div class="container">
                        <div class="row g-4">
                            <!-- Featured big -->
                            <div class="col-lg-8 col-md-6" data-indigo-fade="" data-delay="100" data-indigo-tags="double black">
                                <a href="#" class="indigo-gallery-item d-block position-relative" style="border-radius: 1.5rem; overflow: hidden;">
                                    <div style="aspect-ratio: 16/10;">
                                        <img src="/indigo_theme/static/src/img/photo/home-hero-miami-door.jpg" style="width:100%; height:100%; object-fit:cover; transition: transform 0.6s;" alt=""/>
                                    </div>
                                    <div class="position-absolute bottom-0 start-0 end-0 p-4 text-white" style="background: linear-gradient(transparent, rgba(0,0,0,0.7));">
                                        <div class="small opacity-75 mb-1">Coral Gables, FL · ID03-DD</div>
                                        <div class="h4 mb-0 fw-bold">Modern coastal residence</div>
                                    </div>
                                </a>
                            </div>
                            <div class="col-lg-4 col-md-6" data-indigo-fade="" data-indigo-tags="double black" data-delay="200">
                                <a href="#" class="indigo-gallery-item d-block position-relative" style="border-radius: 1.5rem; overflow: hidden;">
                                    <div style="aspect-ratio: 4/5;">
                                        <img src="/indigo_theme/static/src/img/photo/cat-single-door.jpg" style="width:100%; height:100%; object-fit:cover;" alt=""/>
                                    </div>
                                    <div class="position-absolute bottom-0 start-0 end-0 p-3 text-white" style="background: linear-gradient(transparent, rgba(0,0,0,0.7));">
                                        <div class="small opacity-75 mb-1">Miami Beach · CUSTOM-DD</div>
                                        <div class="fw-bold">Art-deco entrance</div>
                                    </div>
                                </a>
                            </div>

                            <!-- Row 2 -->
                            <div class="col-lg-4 col-md-6" data-indigo-fade="" data-indigo-tags="double custom black" data-delay="100">
                                <a href="#" class="indigo-gallery-item d-block position-relative" style="border-radius: 1.5rem; overflow: hidden;">
                                    <div style="aspect-ratio: 4/5;">
                                        <img src="/indigo_theme/static/src/img/photo/cat-double-door.jpg" style="width:100%; height:100%; object-fit:cover;" alt=""/>
                                    </div>
                                    <div class="position-absolute bottom-0 start-0 end-0 p-3 text-white" style="background: linear-gradient(transparent, rgba(0,0,0,0.7));">
                                        <div class="small opacity-75 mb-1">Aventura · ID07-SD</div>
                                        <div class="fw-bold">Contemporary townhouse</div>
                                    </div>
                                </a>
                            </div>
                            <div class="col-lg-4 col-md-6" data-indigo-fade="" data-indigo-tags="single white" data-delay="200">
                                <a href="#" class="indigo-gallery-item d-block position-relative" style="border-radius: 1.5rem; overflow: hidden;">
                                    <div style="aspect-ratio: 4/5;">
                                        <img src="/indigo_theme/static/src/img/photo/cat-sidelites.jpg" style="width:100%; height:100%; object-fit:cover;" alt=""/>
                                    </div>
                                    <div class="position-absolute bottom-0 start-0 end-0 p-3 text-white" style="background: linear-gradient(transparent, rgba(0,0,0,0.7));">
                                        <div class="small opacity-75 mb-1">Boca Raton · ID10-DD</div>
                                        <div class="fw-bold">Mediterranean villa</div>
                                    </div>
                                </a>
                            </div>
                            <div class="col-lg-4 col-md-6" data-indigo-fade="" data-indigo-tags="double bronze" data-delay="300">
                                <a href="#" class="indigo-gallery-item d-block position-relative" style="border-radius: 1.5rem; overflow: hidden;">
                                    <div style="aspect-ratio: 4/5;">
                                        <img src="/indigo_theme/static/src/img/photo/cat-custom.jpg" style="width:100%; height:100%; object-fit:cover;" alt=""/>
                                    </div>
                                    <div class="position-absolute bottom-0 start-0 end-0 p-3 text-white" style="background: linear-gradient(transparent, rgba(0,0,0,0.7));">
                                        <div class="small opacity-75 mb-1">Naples · CUSTOM-SD</div>
                                        <div class="fw-bold">Luxury beach home</div>
                                    </div>
                                </a>
                            </div>

                            <!-- Row 3: featured + small -->
                            <div class="col-lg-4 col-md-6" data-indigo-fade="" data-indigo-tags="single custom white" data-delay="100">
                                <a href="#" class="indigo-gallery-item d-block position-relative" style="border-radius: 1.5rem; overflow: hidden;">
                                    <div style="aspect-ratio: 4/5;">
                                        <img src="https://images.unsplash.com/photo-1582268611958-ebfd161ef9cf?w=800&amp;q=85" style="width:100%; height:100%; object-fit:cover;" alt=""/>
                                    </div>
                                    <div class="position-absolute bottom-0 start-0 end-0 p-3 text-white" style="background: linear-gradient(transparent, rgba(0,0,0,0.7));">
                                        <div class="small opacity-75 mb-1">Coconut Grove · ID15-DD</div>
                                        <div class="fw-bold">Garden estate</div>
                                    </div>
                                </a>
                            </div>
                            <div class="col-lg-8 col-md-6" data-indigo-fade="" data-indigo-tags="double bronze" data-delay="200">
                                <a href="#" class="indigo-gallery-item d-block position-relative" style="border-radius: 1.5rem; overflow: hidden;">
                                    <div style="aspect-ratio: 16/10;">
                                        <img src="/indigo_theme/static/src/img/photo/lifestyle-hallway-door.jpg" style="width:100%; height:100%; object-fit:cover;" alt=""/>
                                    </div>
                                    <div class="position-absolute bottom-0 start-0 end-0 p-4 text-white" style="background: linear-gradient(transparent, rgba(0,0,0,0.7));">
                                        <div class="small opacity-75 mb-1">Key Biscayne · CUSTOM-DD</div>
                                        <div class="h4 mb-0 fw-bold">Sunset-facing oceanfront</div>
                                    </div>
                                </a>
                            </div>

                            <!-- Row 4 -->
                            <div class="col-lg-4 col-md-6" data-indigo-fade="" data-indigo-tags="double custom black" data-delay="100">
                                <a href="#" class="indigo-gallery-item d-block position-relative" style="border-radius: 1.5rem; overflow: hidden;">
                                    <div style="aspect-ratio: 4/5;">
                                        <img src="/indigo_theme/static/src/img/photo/lifestyle-living-door.jpg" style="width:100%; height:100%; object-fit:cover;" alt=""/>
                                    </div>
                                    <div class="position-absolute bottom-0 start-0 end-0 p-3 text-white" style="background: linear-gradient(transparent, rgba(0,0,0,0.7));">
                                        <div class="small opacity-75 mb-1">Doral · ID22-SD</div>
                                        <div class="fw-bold">Family residence</div>
                                    </div>
                                </a>
                            </div>
                            <div class="col-lg-4 col-md-6" data-indigo-fade="" data-indigo-tags="single white" data-delay="200">
                                <a href="#" class="indigo-gallery-item d-block position-relative" style="border-radius: 1.5rem; overflow: hidden;">
                                    <div style="aspect-ratio: 4/5;">
                                        <img src="/indigo_theme/static/src/img/photo/dealer-program-hero.jpg" style="width:100%; height:100%; object-fit:cover;" alt=""/>
                                    </div>
                                    <div class="position-absolute bottom-0 start-0 end-0 p-3 text-white" style="background: linear-gradient(transparent, rgba(0,0,0,0.7));">
                                        <div class="small opacity-75 mb-1">West Palm · ID30-DD</div>
                                        <div class="fw-bold">Penthouse entry</div>
                                    </div>
                                </a>
                            </div>
                            <div class="col-lg-4 col-md-6" data-indigo-fade="" data-indigo-tags="double black" data-delay="300">
                                <a href="#" class="indigo-gallery-item d-block position-relative" style="border-radius: 1.5rem; overflow: hidden;">
                                    <div style="aspect-ratio: 4/5;">
                                        <img src="/indigo_theme/static/src/img/photo/lifestyle-entrance-wide.jpg" style="width:100%; height:100%; object-fit:cover;" alt=""/>
                                    </div>
                                    <div class="position-absolute bottom-0 start-0 end-0 p-3 text-white" style="background: linear-gradient(transparent, rgba(0,0,0,0.7));">
                                        <div class="small opacity-75 mb-1">Pinecrest · ID18-DD</div>
                                        <div class="fw-bold">Modern farmhouse</div>
                                    </div>
                                </a>
                            </div>
                        </div>

                        <!-- Load more -->
                        <div class="text-center mt-5" data-indigo-fade="">
                            <button class="btn btn-outline-dark btn-lg">Load more projects</button>
                        </div>
                    </div>
                </section>

                <!-- CTA -->
                <section class="indigo-section bg-dark-gradient text-center">
                    <div class="container" style="max-width: 720px;" data-indigo-fade="">
                        <div class="indigo-eyebrow" style="color: rgba(255,255,255,0.85) !important;">Your project next?</div>
                        <h2 class="h-display display-3 mb-4 text-white">Let's build <em>yours.</em></h2>
                        <p class="lead opacity-90 mb-4">
                            Browse our catalog of 142 designs or talk to us about a fully custom door.
                        </p>
                        <div class="d-flex flex-wrap gap-3 justify-content-center">
                            <a href="/shop" class="btn btn-light btn-lg">Browse catalog</a>
                            <a href="/contactus" class="btn btn-outline-light btn-lg">Request a quote</a>
                        </div>
                    </div>
                </section>

            </div>
        </t>
    </template>

    <record id="page_gallery" model="website.page">
        <field name="view_id" ref="view_gallery"/>
        <field name="url">/page/gallery</field>
        <field name="is_published" eval="True"/>
    </record>

</odoo>
