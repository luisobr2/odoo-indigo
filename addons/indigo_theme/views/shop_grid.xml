<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Card image follows the /shop type+color filter.
         Base template renders <span t-field="image_holder.image_1920"> (the
         product cover). We swap it for the design's per-type-per-color photo
         from /indigo/door_image/<design>/<color>?type=<type>. Default SD+black;
         when a filter is active, that type/color. Non-Indigo products keep the
         native cover (t-else). The selected type/color come from
         website.indigo_shop_filters() (reads request.params — no qcontext
         dependency, works for every render of products_item). -->
    <template id="indigo_shop_card_image" inherit_id="website_sale.products_item"
              name="Indigo: shop card image by type+color" priority="30">
        <xpath expr="//span[@t-field='image_holder.image_1920']" position="replace">
            <t t-set="indigo_f" t-value="website.indigo_shop_filters()"/>
            <t t-set="indigo_itype" t-value="indigo_f['type'] or 'SD'"/>
            <t t-set="indigo_icolor" t-value="indigo_f['color'] or 'black'"/>
            <!-- sudo: the /shop grid is public, and indigo_family_types() reads
                 indigo.design (not public-readable). The design id is a
                 non-sensitive value used only to build the image URL. -->
            <t t-set="indigo_ift"
               t-value="[f for f in product.sudo().indigo_family_types() if f['door_type'] == indigo_itype] if product.is_indigo_design else []"/>
            <t t-set="indigo_idesign"
               t-value="(indigo_ift[0]['design_id'] if indigo_ift else (product.sudo().indigo_design_id.id if product.indigo_design_id else False))"/>
            <t t-if="indigo_idesign">
                <!-- Replicate the native image wrapper exactly so the card
                     layout/sizing (theme + website_sale CSS target this
                     structure) stays identical; only the src changes. -->
                <span class="oe_product_image_img_wrapper d-flex h-100 justify-content-center align-items-center position-absolute">
                    <img t-att-src="'/indigo/door_image/%s/%s?type=%s' % (indigo_idesign, indigo_icolor, indigo_itype)"
                         t-att-alt="product.name" loading="lazy" itemprop="image"
                         class="img img-fluid h-100 w-100 position-absolute object-fit-contain"/>
                </span>
            </t>
            <t t-else="">
                <span t-field="image_holder.image_1920"
                      t-options="{'widget': 'image', 'preview_image': image_type, 'itemprop': 'image', 'class': 'h-100 w-100 position-absolute object-fit-contain'}"/>
            </t>
        </xpath>
    </template>

    <!-- Reusable filter panel (Door type + Finish). Rendered in the desktop
         sidebar and the mobile bar. Fixed-column grids keep the chips aligned
         (no ragged flex-wrap); Finish previews the actual door finishes as
         color swatches. Each chip reloads /shop with ?type=/?color= (preserving
         search + the other filter); the active value is filled indigo. -->
    <template id="indigo_shop_filters_inner" name="Indigo: shop filter links">
        <t t-set="indigo_f" t-value="website.indigo_shop_filters()"/>
        <div class="indigo-filters">
            <div class="indigo-filters__group">
                <span class="indigo-filters__label">Door type</span>
                <div class="indigo-filters__grid indigo-filters__grid--3">
                    <a t-att-href="website.indigo_shop_filter_url(set_type='')"
                       t-attf-class="indigo-chip #{'is-active' if not indigo_f['type'] else ''}">All</a>
                    <a t-att-href="website.indigo_shop_filter_url(set_type='SD')"
                       t-attf-class="indigo-chip #{'is-active' if indigo_f['type'] == 'SD' else ''}">Single</a>
                    <a t-att-href="website.indigo_shop_filter_url(set_type='DD')"
                       t-attf-class="indigo-chip #{'is-active' if indigo_f['type'] == 'DD' else ''}">Double</a>
                </div>
            </div>
            <div class="indigo-filters__group">
                <span class="indigo-filters__label">Finish</span>
                <div class="indigo-filters__grid indigo-filters__grid--3">
                    <a t-att-href="website.indigo_shop_filter_url(set_color='')"
                       t-attf-class="indigo-chip indigo-chip--wide #{'is-active' if not indigo_f['color'] else ''}">All finishes</a>
                    <a t-att-href="website.indigo_shop_filter_url(set_color='black')"
                       t-attf-class="indigo-chip #{'is-active' if indigo_f['color'] == 'black' else ''}">
                        <span class="indigo-swatch indigo-swatch--black"/>Black</a>
                    <a t-att-href="website.indigo_shop_filter_url(set_color='white')"
                       t-attf-class="indigo-chip #{'is-active' if indigo_f['color'] == 'white' else ''}">
                        <span class="indigo-swatch indigo-swatch--white"/>White</a>
                    <a t-att-href="website.indigo_shop_filter_url(set_color='bronze')"
                       t-attf-class="indigo-chip #{'is-active' if indigo_f['color'] == 'bronze' else ''}">
                        <span class="indigo-swatch indigo-swatch--bronze"/>Bronze</a>
                </div>
            </div>
        </div>
    </template>

    <!-- Place the filters in the native left sidebar (products_grid_before) on
         desktop, and a horizontal bar on mobile (that sidebar is d-lg-block only).
         The sidebar is gated on hasLeftColumn (False here — no categories), so we
         force it on; the grid moves to col-lg-9 automatically. -->
    <template id="indigo_shop_filter_placement" inherit_id="website_sale.products"
              name="Indigo: shop filters sidebar (desktop) + bar (mobile)" priority="30">
        <!-- desktop: show the left sidebar -->
        <xpath expr="//aside[@id='products_grid_before']" position="before">
            <t t-set="hasLeftColumn" t-value="True"/>
        </xpath>
        <!-- drop the empty category rail's full-height scroll so it sizes to the
             filters -->
        <xpath expr="//div[hasclass('o_wsale_products_grid_before_rail')]" position="attributes">
            <attribute name="class">o_wsale_products_grid_before_rail mt-n2 pt-2 pe-lg-2 ps-2</attribute>
        </xpath>
        <xpath expr="//div[hasclass('o_wsale_products_grid_before_rail')]" position="inside">
            <div class="indigo-shop-filters indigo-shop-filters-side">
                <t t-call="indigo_theme.indigo_shop_filters_inner"/>
            </div>
        </xpath>
        <!-- mobile: horizontal bar above the grid -->
        <xpath expr="//div[hasclass('o_wsale_products_main_row')]" position="before">
            <div class="indigo-shop-filters indigo-shop-filters-bar d-lg-none pt-2 mb-2">
                <t t-call="indigo_theme.indigo_shop_filters_inner"/>
            </div>
        </xpath>
    </template>

</odoo>
