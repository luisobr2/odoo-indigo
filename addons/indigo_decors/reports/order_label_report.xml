<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_order_label" model="ir.actions.report">
        <field name="name">Etiquetas del disenador</field>
        <field name="model">indigo.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">indigo_decors.report_order_label_doc</field>
        <field name="report_file">indigo_decors.report_order_label_doc</field>
        <field name="print_report_name">'Etiquetas %s' % (object.name or '')</field>
        <field name="binding_model_id" ref="model_indigo_order"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_indigo_label"/>
    </record>

    <template id="report_order_label_doc">
        <t t-call="web.html_container">
            <t t-set="all_labels"
               t-value="[(o, l, copy) for o in docs for l in o.line_ids for copy in range(int(l.qty or 1))]"/>
            <t t-foreach="all_labels" t-as="entry">
                <t t-set="o" t-value="entry[0]"/>
                <t t-set="l" t-value="entry[1]"/>
                <!-- TYPE-COLOR-GLASS as one token, e.g. SD-BRONZE-ESW -->
                <t t-set="tcg" t-value="'-'.join([x for x in [
                    {'SD':'SD','DD':'DD','sidelite':'SDL'}.get(l.door_type, (l.door_type or '').upper()),
                    {'white':'WHITE','bronze':'BRONZE','bronze_eco':'BRONZE ECO','black':'BLACK','custom':'CUSTOM'}.get(l.color, (l.color or '').upper()),
                    (l.glass_type or '').upper()] if x])"/>
                <!-- 2-column layout matching the client's reference photo:
                       LEFT col  (~70%) : customer/dealer, dimensions, type-color-glass
                       RIGHT col (~30%) : order#, PRIVACY, Parts N
                     The QR was deferred (the client's reference doesn't show it).
                     To re-enable, see the commented block at the bottom. -->
                <!-- Font sizes tuned to fill the 11 mm content area without
                     overflowing. 6 pt body / 7 pt bold puts the 3 left rows
                     at ~9 mm total and keeps long names on one line. 7 pt
                     was overflowing ("SD bronze" got clipped, "Lock Tight"
                     wrapped). Customer name truncated to 22 chars so the
                     "/ <Dealer>" suffix fits next to it. -->
                <div t-attf-style="font-family: 'Nimbus Sans Narrow','Arial Narrow','Roboto Condensed',Arial,sans-serif; font-size: 6pt; line-height: 1.15; padding: 0; margin: 0; width: 55mm; height: 11mm; overflow: hidden; #{'page-break-before: always;' if not entry_first else ''}">
                    <table style="width:100%; border-collapse: collapse; height: 11mm;">
                        <tr>
                            <!-- LEFT column -->
                            <td style="vertical-align: top; padding-right: 0.8mm; width: 70%; white-space: nowrap;">
                                <!-- 3 lines per the spec: customer/dealer 7pt,
                                     measurements 9pt, TYPE-COLOR-GLASS 9pt bold. -->
                                <div style="font-size: 7pt; overflow: hidden; text-overflow: ellipsis;">
                                    <span t-out="(l.customer_name or o.client_name or '')[:32]"/>
                                    <span> / </span>
                                    <span t-out="(o.dealer_id.name or '').upper()"/>
                                </div>
                                <div style="font-size: 9pt; margin-top: 0.2mm;">
                                    <span t-out="l.width_label or l.width"/> - <span t-out="l.height_label or l.height"/>
                                </div>
                                <div style="font-size: 9pt; font-weight: bold; margin-top: 0.2mm;" t-out="tcg"/>
                            </td>
                            <!-- RIGHT column (8pt): order #, PRIV/CLEAR, Parts -->
                            <td style="vertical-align: top; padding-left: 0.8mm; border-left: 0.3mm solid #000; width: 30%; text-align: left; white-space: nowrap; font-size: 8pt;">
                                <div t-out="o.name or ''"/>
                                <div style="font-weight: bold; margin-top: 0.3mm;">
                                    <t t-if="o.priv_ref">PRIV: <span t-out="o.priv_ref"/></t>
                                    <t t-elif="l.glass_privacy == 'privacy'">PRIV</t>
                                    <t t-else="">CLEAR</t>
                                </div>
                                <div style="margin-top: 0.3mm;">Parts <span t-out="l.parts_count or 1"/></div>
                            </td>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>

    <!--
        Optional: QR code variant (uncomment + replace template above to enable).
        Adds a 10mm QR with order.name on the far right; left + middle columns
        squeezed to fit. Useful when the workshop wants barcode trazability.

        <template id="report_order_label_doc">
          ...
              <td style="width: 11mm; vertical-align: top;">
                  <img t-att-src="'/report/barcode/QR/%s' % (o.name or '0')"
                       style="width: 10mm; height: 10mm;"/>
              </td>
          ...
        </template>
    -->


</odoo>
