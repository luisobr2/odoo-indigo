<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_indigo_order_kanban" model="ir.ui.view">
        <field name="name">indigo.order.kanban</field>
        <field name="model">indigo.order</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" class="o_kanban_small_column" sample="1">
                <field name="name"/>
                <field name="dealer_id"/>
                <field name="client_name"/>
                <field name="client_address"/>
                <field name="priv_ref"/>
                <field name="stage_id"/>
                <field name="on_hold"/>
                <field name="door_count"/>
                <field name="total_sqf"/>
                <field name="payment_state"/>
                <field name="assigned_user_ids"/>
                <field name="days_in_current_stage"/>
                <field name="is_overdue"/>
                <field name="installation_date"/>
                <progressbar field="payment_state"
                             colors='{"paid": "success", "partial": "warning", "unpaid": "danger"}'/>
                <templates>
                    <t t-name="kanban-box">
                        <!-- oe_kanban_global_click is what makes the whole card open the form on click.
                             OWL-style object class binding (Odoo 17 kanban templates use OWL, not legacy QWeb).
                             DO NOT use string concatenation in t-att-class — OWL parser chokes on it. -->
                        <div t-att-class="{
                                'oe_kanban_card': true,
                                'oe_kanban_global_click': true,
                                'o_kanban_card_muted': record.on_hold.raw_value,
                                'border-danger': record.is_overdue.raw_value,
                             }"
                             t-att-style="record.is_overdue.raw_value ? 'border-left: 4px solid #d9534f;' : ''">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title"><field name="name"/></strong>
                                    <span class="o_kanban_record_subtitle text-muted">
                                        <field name="dealer_id"/>
                                        <t t-if="record.priv_ref.raw_value">
                                            &#160;&#xb7;&#160;<field name="priv_ref"/>
                                        </t>
                                    </span>
                                </div>
                                <field name="assigned_user_ids" widget="many2many_avatar_user"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><strong>Customer:</strong> <field name="client_name"/></div>
                                <div t-if="record.client_address.raw_value" class="text-muted small">
                                    <field name="client_address"/>
                                </div>
                                <div t-if="record.installation_date.raw_value" class="text-muted small">
                                    <i class="fa fa-calendar" title="Installation date"/>
                                    <field name="installation_date"/>
                                </div>
                                <div class="mt-1">
                                    <span class="badge text-bg-secondary">
                                        <field name="door_count"/> doors
                                    </span>
                                    <span class="badge text-bg-info">
                                        <field name="total_sqf"/> SQF
                                    </span>
                                    <t t-if="record.on_hold.raw_value">
                                        <span class="badge text-bg-warning ms-1">On hold</span>
                                    </t>
                                    <t t-if="record.is_overdue.raw_value">
                                        <span class="badge text-bg-danger ms-1">
                                            Overdue (<field name="days_in_current_stage"/>d)
                                        </span>
                                    </t>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <!-- Inline payment badge instead of label_selection widget
                                         to avoid OWL widget render quirks that can break clicks. -->
                                    <t t-if="record.payment_state.raw_value == 'paid'">
                                        <span class="badge text-bg-success">Paid</span>
                                    </t>
                                    <t t-if="record.payment_state.raw_value == 'partial'">
                                        <span class="badge text-bg-warning">Partial</span>
                                    </t>
                                    <t t-if="record.payment_state.raw_value == 'unpaid' or not record.payment_state.raw_value">
                                        <span class="badge text-bg-danger">Unpaid</span>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_indigo_order" model="ir.actions.act_window">
        <field name="name">Ordenes</field>
        <field name="res_model">indigo.order</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_indigo_order_search"/>
    </record>

</odoo>
