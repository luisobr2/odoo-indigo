<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Storefront PDP gating.
         The store is dealer-only for pricing/ordering. For the PUBLIC (and any
         logged-in NON-dealer) the product page is a catalog view: no price, no
         dimensions/install form, no cart — just a "Contact sales" CTA.
         A logged-in DEALER (res.partner.is_indigo_dealer) gets the full
         dimensions + per-line install form and the add-to-quote button.

         Dealer test (reused in both templates below):
           (not website.is_public_user())
           and (user.partner_id.is_indigo_dealer
                or user.partner_id.commercial_partner_id.is_indigo_dealer)

         Both inherit website_sale.product and target #o_wsale_cta_wrapper
         (confirmed: that div has no t-if of its own in the base view). -->

    <!-- PDP main image for designs with NO base product image.
         These designs carry their photos only as design attachments (the
         door_image route reads them), not as product.image_1920, so the native
         carousel would serve a placeholder in the HTML and the image would only
         appear after a JS swap → a visible flash on load. Render the door photo
         (design + black) server-side so the browser loads the real image
         directly. theme.js still swaps this same <img> (product_detail_img) when
         the dealer picks a type/color. Products WITH a base image are untouched. -->
    <template id="indigo_pdp_main_image" inherit_id="website_sale.shop_product_image"
              name="Indigo: PDP main image from design photo" priority="20">
        <xpath expr="//div[@t-field='product_image.image_1920' and hasclass('align-items-start')]" position="replace">
            <t t-if="product.is_indigo_design and not product.image_1920 and product.indigo_design_id">
                <!-- Honor the /shop TYPE + COLOR filters (?type=/?color=) so a card
                     clicked from the Single/Double + White/Bronze filter opens on
                     that type and finish. website.indigo_shop_filters() gives the
                     same validated values the grid uses (type SD/DD; color
                     white/bronze/black or ''); the design for that type comes from
                     indigo_family_types() (the Single/Double sibling), color '' ->
                     black. The page cache varies by these SAME expressions (see
                     indigo_product_cache_by_dealer) so the served HTML matches —
                     no JS, no flash. -->
                <t t-set="indigo_pdp_f" t-value="product.env['website'].get_current_website().indigo_shop_filters()"/>
                <t t-set="indigo_pdp_ift" t-value="[f for f in product.indigo_family_types() if f['door_type'] == indigo_pdp_f['type']]"/>
                <t t-set="indigo_pdp_design" t-value="indigo_pdp_ift[0]['design_id'] if indigo_pdp_ift else product.indigo_design_id.id"/>
                <t t-set="indigo_pdp_color" t-value="indigo_pdp_f['color'] or 'black'"/>
                <!-- ?type= mirrors the grid card image so CUSTOM (SD & DD share one
                     design) resolves the right photo; harmless for standard designs
                     (the design_id already encodes the type). -->
                <img t-att-src="'/indigo/door_image/%s/%s?type=%s' % (indigo_pdp_design, indigo_pdp_color, indigo_pdp_f['type'])"
                     t-att-alt="product.name" itemprop="image"
                     class="oe_unmovable product_detail_img mh-100 img img-fluid h-100"/>
            </t>
            <t t-else="">
                <div t-field="product_image.image_1920"
                     class="d-flex align-items-start justify-content-center h-100 oe_unmovable"
                     t-options='{"widget": "image", "preview_image": "image_1024", "class": "oe_unmovable product_detail_img mh-100", "alt-field": "name", "zoom": product_image.can_image_1024_be_zoomed and "image_1920"}'/>
            </t>
        </xpath>
    </template>

    <template id="indigo_product_dimensions" name="Indigo Product Dimensions / Quote (dealers only)"
              inherit_id="website_sale.product" priority="35">
        <xpath expr="//div[@id='o_wsale_cta_wrapper']" position="before">
            <t t-set="indigo_is_dealer"
               t-value="(not website.is_public_user()) and (request.env.user.partner_id.is_indigo_dealer or request.env.user.partner_id.commercial_partner_id.is_indigo_dealer)"/>

            <t t-if="indigo_is_dealer">
                <!-- Dealer base price (shown ONLY to logged-in dealers — this
                     whole block is dealer-gated). Starts at the FILTERED type's
                     price (Double = $600, not the Single $300) via
                     indigo_family_types(); theme.js updates the amount + the
                     product title when the dealer switches the door type. Hidden
                     for quote-only products (CUSTOM, price 0). -->
                <t t-set="indigo_price_ft" t-value="[f for f in product.indigo_family_types() if f['door_type'] == website.indigo_shop_filters()['type']]"/>
                <t t-set="indigo_pdp_price" t-value="indigo_price_ft[0]['price'] if indigo_price_ft else product.indigo_dealer_price"/>
                <t t-if="indigo_pdp_price">
                    <div class="indigo-pdp-price mb-3">
                        <span class="indigo-pdp-price__amount" data-indigo-price="1">$<t t-esc="'{:,.0f}'.format(indigo_pdp_price)"/></span>
                        <span class="indigo-pdp-price__note">Dealer base price</span>
                    </div>
                </t>
                <!-- Per-line install context (homeowner / dealer ref / address /
                     phone). Captured by JS at add-to-cart, persisted onto
                     sale.order.line via WebsiteSaleIndigo.cart_update_json. -->
                <div class="indigo-pdp-install mb-3">
                    <div class="indigo-eyebrow mb-2">For this door</div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="indigo_customer_name" class="form-label small fw-bold">Customer name</label>
                            <input type="text" id="indigo_customer_name" name="indigo_customer_name"
                                   class="form-control" placeholder="Homeowner / final client"
                                   data-indigo-spec="customer_name"/>
                        </div>
                        <div class="col-md-6">
                            <label for="indigo_order_ref" class="form-label small fw-bold">Order ref</label>
                            <input type="text" id="indigo_order_ref" name="indigo_order_ref"
                                   class="form-control" placeholder="Your project / order code"
                                   data-indigo-spec="order_ref"/>
                        </div>
                        <div class="col-md-8">
                            <label for="indigo_install_address" class="form-label small fw-bold">Install address</label>
                            <input type="text" id="indigo_install_address" name="indigo_install_address"
                                   class="form-control" placeholder="Street, City, State ZIP"
                                   data-indigo-spec="install_address"/>
                        </div>
                        <div class="col-md-4">
                            <label for="indigo_install_phone" class="form-label small fw-bold">Install phone</label>
                            <input type="tel" id="indigo_install_phone" name="indigo_install_phone"
                                   class="form-control" placeholder="+1 (305) 555-0000"
                                   data-indigo-spec="install_phone"/>
                        </div>
                    </div>
                    <p class="small text-muted mt-2 mb-0">
                        Optional — leave blank if it's for the dealer's stock.
                        Filled per door so each line in the quote arrives with
                        its install context.
                    </p>
                </div>
                <!-- Door type selector. Options are the types available in the
                     design family (indigo_family_types). The chosen type is
                     posted as indigo_door_type; the server resolves the actual
                     product to order from (family + type) and switches to the
                     Single/Double sibling while preserving the color
                     (indigo_variant_for_type). Each option also carries
                     data-design-id (the sibling design) so theme.js swaps the
                     main photo to that type's door — the image follows the
                     Single/Double pick, not just the color. Shown only when the
                     family offers more than one type. -->
                <t t-set="indigo_types" t-value="product.indigo_family_types()"/>
                <!-- Default selection = the type the shopper filtered by
                     (website.indigo_shop_filters()['type'], SD or DD), so the PDP
                     opens on the type of the card they clicked. If that type isn't
                     in this family, fall back to the card's own type; empty only
                     for a flexible/CUSTOM card with no type (keeps "— Select —"). -->
                <t t-set="indigo_url_type" t-value="website.indigo_shop_filters()['type']"/>
                <t t-set="indigo_my_type"
                   t-value="indigo_url_type if indigo_url_type in [f['door_type'] for f in indigo_types] else (product.indigo_door_type or (product.indigo_design_id.door_type if product.indigo_design_id else ''))"/>
                <t t-if="len(indigo_types) &gt; 1">
                    <div class="indigo-pdp-doortype mb-3">
                        <div class="indigo-eyebrow mb-2">Door type *</div>
                        <select id="indigo_door_type" class="form-select" data-indigo-spec="door_type">
                            <!-- Placeholder only when this card has no natural type
                                 (flexible/CUSTOM); otherwise a real type is preselected. -->
                            <option t-if="not indigo_my_type" value="">— Select —</option>
                            <t t-foreach="indigo_types" t-as="ft">
                                <!-- data-name = that type's nomenclature (ID01-SD / ID01-DD),
                                     data-price = its dealer base price. theme.js updates the
                                     product title + price line when the type changes. Rendered
                                     inside the dealer-only block, so the price never leaks. -->
                                <option t-att-value="ft['door_type']"
                                        t-att-data-design-id="ft['design_id']"
                                        t-att-data-name="ft.get('name') or ''"
                                        t-att-data-price="ft.get('price') or 0"
                                        t-att-selected="'selected' if ft['door_type'] == indigo_my_type else None"><t t-esc="ft['label']"/></option>
                            </t>
                        </select>
                        <p class="small text-muted mt-2 mb-0">
                            Single by default — switch to Double if needed.
                        </p>
                    </div>
                </t>

                <!-- Color / finish selector. Shown ONLY when the product doesn't
                     already carry a Color/Finish variant attribute (some CUSTOM
                     products do) — otherwise the variant captures the color and
                     a second picker would be redundant/conflicting. Options come
                     from the design's allowed_colors when set (managed in the
                     panel's family editor), else standard White / Bronze / Black. -->
                <t t-set="indigo_has_color_variant"
                   t-value="any([('color' in (al.attribute_id.name or '').lower() or 'finish' in (al.attribute_id.name or '').lower()) for al in product.attribute_line_ids])"/>
                <t t-if="not indigo_has_color_variant">
                    <div class="indigo-pdp-color mb-3">
                        <div class="indigo-eyebrow mb-2">Color / Finish *</div>
                        <t t-set="indigo_design" t-value="product.indigo_design_id"/>
                        <!-- Storefront finishes: normalize + keep only canonical
                             dealer-facing codes. 'custom' is intentionally NOT
                             offered here — it needs a described color and is
                             handled off-band by sales. -->
                        <t t-set="indigo_valid_colors" t-value="['white', 'bronze', 'bronze_eco', 'black']"/>
                        <t t-set="indigo_colors"
                           t-value="([c.strip().lower() for c in indigo_design.allowed_colors.split(',') if c.strip().lower() in indigo_valid_colors] or ['white', 'bronze', 'black']) if (indigo_design and indigo_design.allowed_colors) else ['white', 'bronze', 'black']"/>
                        <t t-set="indigo_color_labels"
                           t-value="{'white': 'White', 'bronze': 'Bronze', 'bronze_eco': 'Bronze ECO', 'black': 'Black'}"/>
                        <!-- Preselect the /shop color filter (?color=) so a card
                             clicked from a finish filter opens on that finish —
                             mirrors the door-type preselect and the main image.
                             Only if this design actually offers it; else the
                             "— Select —" placeholder stays the default. -->
                        <t t-set="indigo_sel_color" t-value="website.indigo_shop_filters()['color']"/>
                        <t t-set="indigo_sel_color" t-value="indigo_sel_color if indigo_sel_color in indigo_colors else ''"/>
                        <!-- data-indigo-design = this card's own design, the
                             default when no door type is picked yet. theme.js
                             builds the photo URL /indigo/door_image/<design>/<color>
                             from the SELECTED type's design (data-design-id on the
                             door-type options) and this color, so the image
                             follows BOTH the type and the color. -->
                        <select id="indigo_color" class="form-select" data-indigo-spec="color"
                                t-att-data-indigo-design="indigo_design.id if indigo_design else ''">
                            <option t-if="not indigo_sel_color" value="">— Select —</option>
                            <t t-foreach="indigo_colors" t-as="c">
                                <option t-att-value="c"
                                        t-att-selected="'selected' if c == indigo_sel_color else None"><t t-esc="indigo_color_labels.get(c) or c"/></option>
                            </t>
                        </select>
                        <p class="small text-muted mt-2 mb-0">
                            Required — the finish/color of the door.
                        </p>
                    </div>
                </t>

                <div class="indigo-pdp-glass mb-3">
                    <div class="indigo-eyebrow mb-2">Brand &amp; glass</div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="indigo_brand" class="form-label small fw-bold">Brand *</label>
                            <select id="indigo_brand" class="form-select" data-indigo-spec="brand_id">
                                <option value="">— Select brand —</option>
                                <t t-foreach="request.env['indigo.brand'].sudo().search([('active','=',True)], order='name')" t-as="b">
                                    <option t-att-value="b.id"><t t-esc="b.name"/></option>
                                </t>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="indigo_privacy" class="form-label small fw-bold">Glass *</label>
                            <select id="indigo_privacy" class="form-select" data-indigo-spec="glass_privacy">
                                <option value="">— Select —</option>
                                <option value="clear">Clear</option>
                                <option value="privacy">Privacy</option>
                            </select>
                        </div>
                    </div>
                    <p class="small text-muted mt-2 mb-0">
                        Required — the brand sets the paint tone and Clear vs
                        Privacy changes the finishing.
                    </p>
                </div>
                <div class="indigo-pdp-dimensions mb-3">
                    <div class="indigo-eyebrow mb-2">Dimensions</div>
                    <div class="row g-3">
                        <div class="col-6">
                            <label for="indigo_door_width" class="form-label small fw-bold">Width</label>
                            <div class="input-group">
                                <input type="text" id="indigo_door_width" name="indigo_door_width"
                                       class="form-control" placeholder="36" inputmode="decimal"
                                       pattern="[0-9 /]*"
                                       data-indigo-spec="width"/>
                                <span class="input-group-text">in</span>
                            </div>
                            <small class="text-muted">e.g. <code>36</code> or <code>36 4/8</code></small>
                        </div>
                        <div class="col-6">
                            <label for="indigo_door_height" class="form-label small fw-bold">Height</label>
                            <div class="input-group">
                                <input type="text" id="indigo_door_height" name="indigo_door_height"
                                       class="form-control" placeholder="80" inputmode="decimal"
                                       pattern="[0-9 /]*"
                                       data-indigo-spec="height"/>
                                <span class="input-group-text">in</span>
                            </div>
                            <small class="text-muted">e.g. <code>80</code> or <code>96 4/8</code></small>
                        </div>
                    </div>
                    <p class="small text-muted mt-2 mb-0">
                        Format: inches and eighths (US door-trade standard).
                        Sales reviews and confirms exact measurements before
                        production.
                    </p>
                </div>

                <!-- Reference attachments: contract scan, photo of the door /
                     opening, sketch, etc. Optional, several files allowed.
                     Sent with the order as multipart and attached to the
                     production order chatter. -->
                <div class="indigo-pdp-files mb-3">
                    <div class="indigo-eyebrow mb-2">Reference photos / documents</div>
                    <input type="file" id="indigo_reference_files" name="indigo_reference_files"
                           class="form-control" multiple="multiple"
                           accept="image/*,.pdf,.doc,.docx"/>
                    <div id="indigo_files_list" class="small text-muted mt-2"></div>
                    <p class="small text-muted mt-1 mb-0">
                        Optional — attach the contract, a photo of the door or
                        opening, or any reference. You can select several files
                        (max 10 files, 25 MB total). Images, PDF or Word.
                    </p>
                </div>

                <!-- CSRF token for the multipart POST to /indigo/order/submit
                     (the JS appends it to the FormData). -->
                <input type="hidden" id="indigo_csrf_token" t-att-value="request.csrf_token()"/>

                <!-- Cart-less ordering: this button submits the whole order
                     (this door + the data above) straight to production via
                     /indigo/order/submit. No cart, no checkout. -->
                <div class="indigo-pdp-place mb-3">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <label for="indigo_qty" class="form-label small fw-bold mb-0">Qty</label>
                        <input type="number" id="indigo_qty" min="1" value="1"
                               class="form-control" style="width:90px"/>
                        <button type="button" id="indigo_place_order"
                                class="btn btn-primary btn-lg flex-grow-1">
                            <i class="fa fa-paper-plane me-2"/>Place order
                        </button>
                    </div>
                    <p class="small text-muted mt-2 mb-0">
                        Submits this order directly to our sales team — no cart.
                        You'll get pricing and payment instructions within 24h.
                    </p>
                </div>
            </t>

            <t t-else="">
                <!-- Public / non-dealer: catalog view + contact CTA. -->
                <div class="indigo-pdp-contact mb-3">
                    <div class="indigo-eyebrow mb-2">Interested in this door?</div>
                    <p class="small text-muted mb-3">
                        Pricing and orders are handled by our sales team. Contact us
                        for a personalized quote.
                    </p>
                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-primary"
                           t-attf-href="mailto:sales@indigodecors.com?subject=Quote request: #{product.name}">
                            <i class="fa fa-envelope me-2"/>Contact sales
                        </a>
                        <a class="btn btn-outline-secondary" href="tel:+17863022732">
                            <i class="fa fa-phone me-2"/>+1 786-302-2732
                        </a>
                    </div>
                </div>
            </t>
        </xpath>
    </template>

    <!-- Cart removed from the flow: hide Odoo's quantity + add-to-cart wrapper
         for everyone. Dealers order via the "Place order" button above;
         the public sees the contact CTA. -->
    <template id="indigo_product_cta_gate" name="Indigo PDP cart hidden"
              inherit_id="website_sale.product" priority="45">
        <xpath expr="//div[@id='o_wsale_cta_wrapper']" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>
    </template>

    <!-- Cart removed from the flow → hide the header cart icon. Done via CSS
         (.o_wsale_my_cart) NOT by deactivating website_sale.header_cart_link:
         the header t-calls that view, so deactivating it 500s every page. -->

    <!-- website_sale.product wraps the whole product detail in a fragment cache
         t-cache="pricelist,product,fiscal_position". That key does NOT include
         who is viewing, but our order form is dealer-gated inside that fragment:
         whoever renders a product first (typically a public visitor) caches the
         public "Contact sales" branch, and every dealer then gets that cached
         public version — the order form never shows. Add the dealer flag to the
         cache key so the dealer view and the public view are cached separately.
         (Same discriminator as indigo_is_dealer in the template above.) -->
    <template id="indigo_product_cache_by_dealer" inherit_id="website_sale.product"
              name="Indigo: vary product page cache by dealer status" priority="20">
        <xpath expr="//*[@t-cache='pricelist,product,fiscal_position']" position="attributes">
            <!-- Also vary by the /shop TYPE + COLOR filters: the main image,
                 title, price and selectors render server-side from
                 website.indigo_shop_filters() (type SD/DD; color white/bronze/
                 black or ''), so the cached HTML must be keyed by both or the
                 first type/finish rendered would be served to everyone. Each is
                 bounded (type 2 values, color 4) and comma-free — the t-cache
                 list is comma-split, so no tuple literals here. -->
            <attribute name="t-cache">pricelist,product,fiscal_position,(not website.is_public_user()) and (request.env.user.partner_id.is_indigo_dealer or request.env.user.partner_id.commercial_partner_id.is_indigo_dealer),website.indigo_shop_filters()['type'],website.indigo_shop_filters()['color']</attribute>
        </xpath>
    </template>

    <!-- PDP title follows the /shop TYPE filter: a card clicked under the Double
         filter opens on the Double product name ("ID01 Double Door"), matching
         the image/price/selector. There is one published card per family (the
         Single), so without this the h1 would always read "Single" even for a
         Double-filtered click. indigo_family_types()['name'] is the sibling's
         product name (same value the grid card shows). Non-Indigo products and
         missing types fall back to product.name. Cached HTML varies by type (see
         indigo_product_cache_by_dealer). itemprop="name" kept for SEO + theme.js
         (which still swaps the title when the dealer changes the door type). -->
    <template id="indigo_pdp_title_by_type" inherit_id="website_sale.product"
              name="Indigo: PDP title follows the /shop type filter" priority="20">
        <xpath expr="//h1[@itemprop='name']" position="replace">
            <t t-set="indigo_title_ft"
               t-value="[f for f in product.indigo_family_types() if f['door_type'] == website.indigo_shop_filters()['type']] if product.is_indigo_design else []"/>
            <h1 itemprop="name"><t t-esc="indigo_title_ft[0]['name'] if indigo_title_ft else product.name"/></h1>
        </xpath>
    </template>

</odoo>
