<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inject CSS directo en <head> (bypass del bundle system) -->
    <template id="indigo_inject_css" name="Indigo CSS Inject"
              inherit_id="website.layout" priority="50">
        <xpath expr="//head" position="inside">
            <link rel="stylesheet" type="text/css" href="/indigo_theme/static/src/css/theme.css"/>
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700;800;900&amp;display=swap" rel="stylesheet"/>
        </xpath>
    </template>

    <!-- TopBar ticker arriba del header -->
    <template id="indigo_top_ticker" name="Indigo Top Ticker"
              inherit_id="website.layout" priority="50">
        <xpath expr="//header[@id='top']" position="before">
            <div class="bg-dark text-white text-center py-2 small" style="background:#111 !important;">
                <div class="container d-flex justify-content-center align-items-center gap-4 flex-wrap">
                    <span>Free shipping on orders over $2,000 across Florida</span>
                    <span class="d-none d-md-inline">·</span>
                    <a href="/dealer-program" class="text-white text-decoration-none">Become a dealer →</a>
                </div>
            </div>
        </xpath>
    </template>

    <!-- Asegurar que website.menu_search aparezca y agregar wishlist + sign-in -->
    <!-- (Odoo 17 ya tiene esto en website.layout, no necesitamos overrides agresivos) -->

</odoo>
