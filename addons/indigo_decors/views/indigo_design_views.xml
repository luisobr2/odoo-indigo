<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_indigo_design_tree" model="ir.ui.view">
        <field name="name">indigo.design.tree</field>
        <field name="model">indigo.design</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="name"/>
                <field name="door_type"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_indigo_design_form" model="ir.ui.view">
        <field name="name">indigo.design.form</field>
        <field name="model">indigo.design</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="door_type"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Descripcion..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_indigo_design_kanban" model="ir.ui.view">
        <field name="name">indigo.design.kanban</field>
        <field name="model">indigo.design</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="code"/>
                <field name="name"/>
                <field name="door_type"/>
                <field name="image"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('indigo.design', 'image', record.id.raw_value)" alt="diseno"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong><field name="code"/></strong>
                                <div><field name="name"/></div>
                                <div class="text-muted"><field name="door_type"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_indigo_design" model="ir.actions.act_window">
        <field name="name">Catalogo de disenos</field>
        <field name="res_model">indigo.design</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>

</odoo>
