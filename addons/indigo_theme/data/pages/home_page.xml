<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="view_home" inherit_id="website.homepage" name="Indigo Home">
        <xpath expr="//div[@id='wrap']" position="replace">
            <div id="wrap" class="oe_structure oe_empty">

                <!-- ===== HERO SPLIT (50/50: copy izquierda + door image derecha) =====
                     Inspirado en las referencias de UI del cliente (B Home,
                     Furniture peach). Mantiene el feel "premium catalog"
                     en vez del fullbleed cinematic anterior. -->
                <section class="indigo-hero-split">
                    <div class="container">
                        <div class="row align-items-center g-5 g-lg-6">
                            <div class="col-lg-6 indigo-hero-split__copy">
                                <div class="indigo-eyebrow" data-indigo-fade="">Spring 2026 · New Collection</div>
                                <h1 class="h-display" data-indigo-fade="" data-delay="100">
                                    A door that <em>tells</em><br/>your story.
                                </h1>
                                <p class="lead text-muted" data-indigo-fade="" data-delay="200">
                                    Hand-crafted decorative doors. 142 designs, made in Miami.
                                </p>
                                <div class="d-flex flex-column flex-sm-row flex-wrap gap-3 gap-md-4 mt-5" data-indigo-fade="" data-delay="300">
                                    <a href="/shop" class="btn btn-primary btn-lg w-100 w-sm-auto">Shop now →</a>
                                    <a href="#categories" class="btn btn-outline-primary btn-lg w-100 w-sm-auto">Get inspired</a>
                                </div>
                            </div>
                            <div class="col-lg-6 indigo-hero-split__visual" data-indigo-fade="" data-delay="200" data-indigo-reveal="">
                                <img src="/indigo_theme/static/src/img/photo/home-hero-miami-door.jpg"
                                     alt="Indigo decorative door · Miami"/>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ===== CATEGORY TILES ===== -->
                <section id="categories" class="indigo-section">
                    <div class="container">
                        <div class="d-flex justify-content-between align-items-end mb-5" data-indigo-fade="">
                            <div>
                                <div class="indigo-eyebrow">Catalog</div>
                                <h2 class="h-display display-3 mb-0">Shop by category</h2>
                            </div>
                            <a href="/shop" class="text-dark text-decoration-underline fw-bold d-none d-md-inline">See everything →</a>
                        </div>
                        <div class="row g-4">
                            <div class="col-6 col-lg-3" data-indigo-fade="" data-delay="100">
                                <a href="/shop?attribute_value=53" class="indigo-tile">
                                    <div class="tile-img">
                                        <img src="/indigo_theme/static/src/img/photo/cat-single-door.jpg" alt="Single doors"/>
                                    </div>
                                    <h3>Single doors</h3>
                                    <p>Quote on request · Multiple designs</p>
                                </a>
                            </div>
                            <div class="col-6 col-lg-3" data-indigo-fade="" data-delay="200">
                                <a href="/shop" class="indigo-tile">
                                    <div class="tile-img">
                                        <img src="/indigo_theme/static/src/img/photo/cat-double-door.jpg" alt="Double doors"/>
                                    </div>
                                    <h3>Double doors</h3>
                                    <p>Quote on request · Multiple designs</p>
                                </a>
                            </div>
                            <div class="col-6 col-lg-3" data-indigo-fade="" data-delay="300">
                                <a href="/shop" class="indigo-tile">
                                    <div class="tile-img">
                                        <img src="/indigo_theme/static/src/img/photo/cat-sidelites.jpg" alt="Sidelites"/>
                                    </div>
                                    <h3>Sidelites</h3>
                                    <p>Quote on request · Pair with any door</p>
                                </a>
                            </div>
                            <div class="col-6 col-lg-3" data-indigo-fade="" data-delay="400">
                                <a href="/contactus?subject=Custom%20door%20inquiry" class="indigo-tile">
                                    <div class="tile-img">
                                        <img src="/indigo_theme/static/src/img/photo/cat-custom.jpg" alt="Custom"/>
                                    </div>
                                    <h3>Custom design</h3>
                                    <p>Tell us your idea — we'll quote it</p>
                                </a>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ===== LIFESTYLE MOSAIC (Apple-style asymmetric) ===== -->
                <section class="indigo-section bg-soft">
                    <div class="container">
                        <div class="mb-5" data-indigo-fade="">
                            <div class="indigo-eyebrow">In real homes</div>
                            <h2 class="h-display display-3 mb-3">See it <em>installed.</em></h2>
                            <p class="lead text-muted" style="max-width: 600px;">
                                Every Indigo door becomes part of a story. Browse recent installations across Florida.
                            </p>
                        </div>
                        <div class="indigo-mosaic" data-indigo-fade="" data-delay="100">
                            <a href="/page/gallery">
                                <img src="/indigo_theme/static/src/img/photo/home-hero-miami-door.jpg" alt="Modern home"/>
                            </a>
                            <a href="/page/gallery">
                                <img src="/indigo_theme/static/src/img/photo/cat-double-door.jpg" alt="Entrance"/>
                            </a>
                            <a href="/page/gallery">
                                <img src="/indigo_theme/static/src/img/photo/lifestyle-living-door.jpg" alt="Living"/>
                            </a>
                            <a href="/page/gallery">
                                <img src="/indigo_theme/static/src/img/photo/lifestyle-hallway-door.jpg" alt="Hallway"/>
                            </a>
                        </div>
                    </div>
                </section>

                <!-- ===== FEATURED PRODUCTS — tabbed (Single / Double / Custom) =====
                     Patron de las referencias del cliente (PressMart). Adaptado
                     al catalogo Indigo: en vez de New/BestSeller/TopRated
                     (no aplicable B2B quote-only) usamos los 3 tipos de
                     puerta reales. -->
                <section class="indigo-section">
                    <div class="container">
                        <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3" data-indigo-fade="">
                            <div>
                                <div class="indigo-eyebrow">Featured</div>
                                <h2 class="h-display display-3 mb-0">From the catalog</h2>
                            </div>
                            <a href="/shop" class="text-dark text-decoration-underline fw-bold d-none d-md-inline">View all 142 designs →</a>
                        </div>
                        <div class="indigo-tabs" data-indigo-fade="" data-delay="100">
                            <button class="indigo-tab is-active" data-indigo-tab="single">Single doors</button>
                            <button class="indigo-tab" data-indigo-tab="double">Double doors</button>
                            <button class="indigo-tab" data-indigo-tab="custom">Custom</button>
                        </div>

                        <t t-set="featured_single" t-value="request.env['product.template'].sudo().search([('is_indigo_design','=',True),('is_published','=',True),('name','ilike','-SD')], limit=8)"/>
                        <t t-set="featured_double" t-value="request.env['product.template'].sudo().search([('is_indigo_design','=',True),('is_published','=',True),('name','ilike','-DD')], limit=8)"/>
                        <t t-set="featured_custom" t-value="request.env['product.template'].sudo().search([('is_indigo_design','=',True),('is_published','=',True),('name','ilike','CUSTOM')], limit=8)"/>

                        <div class="indigo-tab-panel is-active" data-indigo-tab-panel="single">
                            <div class="row g-4">
                                <t t-foreach="featured_single" t-as="product">
                                    <div class="col-6 col-md-4 col-lg-3" data-indigo-fade="" t-att-data-delay="(product_index % 4) * 100">
                                        <a t-att-href="product.website_url" class="indigo-tile">
                                            <div class="tile-img">
                                                <img t-att-src="'/web/image/product.template/%s/image_1920' % product.id" t-att-alt="product.name"/>
                                            </div>
                                            <h3 t-out="product.name"/>
                                            <p>Single Door</p>
                                        </a>
                                    </div>
                                </t>
                            </div>
                        </div>
                        <div class="indigo-tab-panel" data-indigo-tab-panel="double">
                            <div class="row g-4">
                                <t t-foreach="featured_double" t-as="product">
                                    <div class="col-6 col-md-4 col-lg-3">
                                        <a t-att-href="product.website_url" class="indigo-tile">
                                            <div class="tile-img">
                                                <img t-att-src="'/web/image/product.template/%s/image_1920' % product.id" t-att-alt="product.name"/>
                                            </div>
                                            <h3 t-out="product.name"/>
                                            <p>Double Door</p>
                                        </a>
                                    </div>
                                </t>
                            </div>
                        </div>
                        <div class="indigo-tab-panel" data-indigo-tab-panel="custom">
                            <div class="row g-4">
                                <t t-foreach="featured_custom" t-as="product">
                                    <div class="col-6 col-md-4 col-lg-3">
                                        <a t-att-href="product.website_url" class="indigo-tile">
                                            <div class="tile-img">
                                                <img t-att-src="'/web/image/product.template/%s/image_1920' % product.id" t-att-alt="product.name"/>
                                            </div>
                                            <h3 t-out="product.name"/>
                                            <p>Custom</p>
                                        </a>
                                    </div>
                                </t>
                            </div>
                        </div>

                        <div class="text-center mt-5">
                            <a href="/shop" class="btn btn-outline-dark btn-lg">Browse all 142 designs →</a>
                        </div>
                    </div>
                </section>

                <!-- ===== MIAMI MAKERS SECTION ===== -->
                <section class="indigo-section bg-dark-gradient">
                    <div class="container">
                        <div class="row align-items-center g-5">
                            <div class="col-lg-7" data-indigo-fade="">
                                <div class="indigo-eyebrow" style="color: rgba(255,255,255,0.85) !important;">Made in Miami</div>
                                <h2 class="h-display display-3 mb-4 text-white">
                                    Designed for Florida.<br/><em>Built to spec.</em>
                                </h2>
                                <p class="lead opacity-90 mb-4">
                                    Every door is quoted, designed and finished to the dealer's project — no two installations alike.
                                </p>
                                <a href="/shop" class="btn btn-light btn-lg">Browse the catalog →</a>
                            </div>
                            <div class="col-lg-5" data-indigo-fade="" data-delay="200">
                                <div style="aspect-ratio: 4/5; border-radius: 1.5rem; overflow: hidden;">
                                    <img src="/indigo_theme/static/src/img/photo/workshop-craftsman-side.jpg"
                                         style="width:100%; height:100%; object-fit:cover;" alt="Workshop"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ===== DEALER PROGRAM ===== -->
                <section class="indigo-section bg-dark text-white">
                    <div class="container">
                        <div class="row align-items-center g-5">
                            <div class="col-lg-7" data-indigo-fade="">
                                <div class="indigo-eyebrow text-white-50">Indigo Dealer Program</div>
                                <h2 class="h-display display-3 mb-4 text-white">
                                    For pros who<br/><em>sell at scale.</em>
                                </h2>
                                <p class="lead text-white-50 mb-4">
                                    Dealer pricing, co-branded materials and full order tracking from quote to installation.
                                </p>
                                <a href="/page/dealer-program#apply" class="btn btn-primary btn-lg me-2">Apply now</a>
                                <a href="/page/dealer-program#benefits" class="text-white text-decoration-underline">Learn about the program</a>
                            </div>
                            <div class="col-lg-5" data-indigo-fade="" data-delay="200">
                                <div style="aspect-ratio: 4/5; border-radius: 1.5rem; overflow: hidden;">
                                    <img src="/indigo_theme/static/src/img/photo/dealer-program-hero.jpg"
                                         style="width:100%; height:100%; object-fit:cover;" alt="Dealers"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ===== HOW IT WORKS BAND ===== -->
                <section class="indigo-section bg-soft">
                    <div class="container">
                        <div class="text-center mb-5" data-indigo-fade="">
                            <div class="indigo-eyebrow">How it works</div>
                            <h2 class="h-display display-4 mb-3">From catalog to install.</h2>
                            <p class="lead text-muted" style="max-width: 700px; margin: 0 auto;">
                                Every Indigo order follows the same four steps — transparent for the dealer at every stage.
                            </p>
                        </div>
                        <div class="row g-4 g-lg-5 text-center">
                            <div class="col-6 col-md-3" data-indigo-fade="" data-delay="100">
                                <div class="mb-3 d-inline-flex align-items-center justify-content-center"
                                     style="width:72px;height:72px;border-radius:9999px;background:rgba(31,68,134,0.08);color:#1f4486;">
                                    <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                                </div>
                                <h4 class="fw-bold mb-1" style="font-size:1.1rem;">1. Quote request</h4>
                                <p class="small text-muted mb-0">Dealer or homeowner submits the design + shipping details.</p>
                            </div>
                            <div class="col-6 col-md-3" data-indigo-fade="" data-delay="200">
                                <div class="mb-3 d-inline-flex align-items-center justify-content-center"
                                     style="width:72px;height:72px;border-radius:9999px;background:rgba(31,68,134,0.08);color:#1f4486;">
                                    <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                                </div>
                                <h4 class="fw-bold mb-1" style="font-size:1.1rem;">2. Tailored quote</h4>
                                <p class="small text-muted mb-0">Our team replies with pricing, lead time and payment instructions.</p>
                            </div>
                            <div class="col-6 col-md-3" data-indigo-fade="" data-delay="300">
                                <div class="mb-3 d-inline-flex align-items-center justify-content-center"
                                     style="width:72px;height:72px;border-radius:9999px;background:rgba(31,68,134,0.08);color:#1f4486;">
                                    <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                </div>
                                <h4 class="fw-bold mb-1" style="font-size:1.1rem;">3. Hand-crafted</h4>
                                <p class="small text-muted mb-0">Doors are cut, finished and prepared in our Miami workshop.</p>
                            </div>
                            <div class="col-6 col-md-3" data-indigo-fade="" data-delay="400">
                                <div class="mb-3 d-inline-flex align-items-center justify-content-center"
                                     style="width:72px;height:72px;border-radius:9999px;background:rgba(31,68,134,0.08);color:#1f4486;">
                                    <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                                </div>
                                <h4 class="fw-bold mb-1" style="font-size:1.1rem;">4. Delivered &amp; installed</h4>
                                <p class="small text-muted mb-0">Coordinated delivery and on-site install across Florida.</p>
                            </div>
                        </div>
                    </div>
                </section>

            </div>
        </xpath>
    </template>

</odoo>
