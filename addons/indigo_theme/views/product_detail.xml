<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Request-a-quote replacement: render a Quote CTA where the price/cart sit.
         CSS + theme.js hide the original buy-now and inject .indigo-quote-cta;
         this template adds a server-rendered fallback so even non-JS visitors
         see the CTA and never see a $ 0.00 price. -->
    <template id="indigo_product_quote_cta" name="Indigo Product Quote CTA"
              inherit_id="website_sale.product_price" priority="40">
        <xpath expr="." position="after">
            <div class="indigo-pdp-quote-block mt-3">
                <span class="indigo-price-on-request">Price on request — every door is quoted to spec</span>
                <p class="small text-muted mt-2 mb-3">
                    Indigo doors are quoted per project. Pricing depends on dealer,
                    finish, privacy glass option, door brand compatibility and total SQF.
                </p>
                <a t-att-href="'/contactus?subject=' + ('Quote request — ' + (product.name or '')).replace(' ', '+')"
                   class="indigo-quote-cta">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    <span>Request a quote</span>
                </a>
            </div>
        </xpath>
    </template>

    <!-- Trust badges debajo del add-to-cart en pagina producto -->
    <template id="indigo_product_trust_badges" name="Indigo Product Trust Badges"
              inherit_id="website_sale.product_buy_now" priority="50">
        <xpath expr="." position="after">
            <div class="indigo-product-trust">
                <div>
                    <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                    </svg>
                    <div>
                        <strong>Hurricane-tested</strong>
                        <span class="text-muted">Florida HVHZ approved</span>
                    </div>
                </div>
                <div>
                    <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                    <div>
                        <strong>Free delivery</strong>
                        <span class="text-muted">Across Florida</span>
                    </div>
                </div>
                <div>
                    <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                    </svg>
                    <div>
                        <strong>10-year warranty</strong>
                        <span class="text-muted">On every door</span>
                    </div>
                </div>
                <div>
                    <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <div>
                        <strong>14-day install</strong>
                        <span class="text-muted">From order to door</span>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

</odoo>
