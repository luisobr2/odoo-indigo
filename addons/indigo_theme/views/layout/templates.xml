              inherit_id="website.layout" priority="50">
        <xpath expr="//header[@id='top']" position="before">
            <div class="bg-dark text-white py-2 small indigo-topbar">
                <div class="container d-flex justify-content-between align-items-center">
                    <span class="d-none d-md-inline" aria-hidden="true"></span>
                    <a href="/page/dealer-program" class="text-white text-decoration-none indigo-topbar-cta">Become a dealer →</a>
                    <div class="d-none d-md-flex align-items-center gap-3 indigo-topbar-phones">
                        <a href="tel:+13057856666" class="text-white text-decoration-none d-inline-flex align-items-center gap-2">
