#. module: indigo_decors
#: model:mail.template,body_html:indigo_decors.mail_template_stage_change
msgid ""
"<div style=\"font-family: Arial, sans-serif; max-width: 600px;\">\n"
"    <h2 style=\"color: #1f4486;\">Indigo Decors</h2>\n"
"    <p>Hola,</p>\n"
"    <p>La orden <strong t-out=\"object.name\"></strong> del dealer\n"
"       <strong t-out=\"object.dealer_id.name\"></strong> entro en la etapa\n"
"       <strong t-out=\"object.stage_id.name\"></strong>.</p>\n"
"    <table style=\"border-collapse: collapse; width: 100%; margin-top: 12px;\">\n"
"        <tr>\n"
"            <td style=\"padding: 6px 10px; background: #f5f7fb;\"><strong>Cliente final</strong></td>\n"
"            <td style=\"padding: 6px 10px;\" t-out=\"object.client_name or '-'\"></td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 6px 10px; background: #f5f7fb;\"><strong>Direccion</strong></td>\n"
"            <td style=\"padding: 6px 10px;\" t-out=\"object.client_address or '-'\"></td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 6px 10px; background: #f5f7fb;\"><strong>Puertas</strong></td>\n"
"            <td style=\"padding: 6px 10px;\" t-out=\"object.door_count\"></td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 6px 10px; background: #f5f7fb;\"><strong>SQF total</strong></td>\n"
"            <td style=\"padding: 6px 10px;\" t-out=\"object.total_sqf\"></td>\n"
"        </tr>\n"
"    </table>\n"
"    <p style=\"margin-top: 18px;\">\n"
"        <a t-att-href=\"'/odoo/action-base.action_partner_form/' + str(object.id)\" style=\"background:#1f4486;color:#fff;padding:8px 16px;text-decoration:none;border-radius:4px;\">\n"
"            Abrir orden\n"
"        </a>\n"
"    </p>\n"
"    <p style=\"color:#888; font-size: 12px; margin-top: 24px;\">\n"
"        Notificacion automatica del sistema Indigo Decors.\n"
"    </p>\n"
"</div>\n"
"            "
msgstr ""

