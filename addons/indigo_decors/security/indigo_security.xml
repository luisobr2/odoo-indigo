<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="module_category_indigo" model="ir.module.category">
            <field name="name">Indigo Decors</field>
            <field name="description">Modulo de gestion de ordenes Indigo</field>
            <field name="sequence">20</field>
        </record>

        <record id="group_indigo_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_indigo"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_indigo_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_indigo"/>
            <field name="implied_ids" eval="[(4, ref('group_indigo_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <record id="group_indigo_contractor" model="res.groups">
            <field name="name">Contractor (portal)</field>
            <field name="category_id" ref="module_category_indigo"/>
            <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
        </record>

        <!-- Subgrupos por area (heredan de User) -->
        <record id="group_indigo_designer" model="res.groups">
            <field name="name">Disenador</field>
            <field name="category_id" ref="module_category_indigo"/>
            <field name="implied_ids" eval="[(4, ref('group_indigo_user'))]"/>
        </record>
        <record id="group_indigo_cnc" model="res.groups">
            <field name="name">CNC / Router</field>
            <field name="category_id" ref="module_category_indigo"/>
            <field name="implied_ids" eval="[(4, ref('group_indigo_user'))]"/>
        </record>
        <record id="group_indigo_painter_op" model="res.groups">
            <field name="name">Pintor</field>
            <field name="category_id" ref="module_category_indigo"/>
            <field name="implied_ids" eval="[(4, ref('group_indigo_user'))]"/>
        </record>
        <record id="group_indigo_office" model="res.groups">
            <field name="name">Office / Administracion</field>
            <field name="category_id" ref="module_category_indigo"/>
            <field name="implied_ids" eval="[(4, ref('group_indigo_user'))]"/>
        </record>

        <!-- Internal installer (uses backend, not portal — for crews on payroll
             that get a real Odoo login). Portal-only installers go in
             group_indigo_contractor / base.group_portal instead. -->
        <record id="group_indigo_installer_internal" model="res.groups">
            <field name="name">Installer (internal)</field>
            <field name="category_id" ref="module_category_indigo"/>
            <field name="implied_ids" eval="[(4, ref('group_indigo_user'))]"/>
        </record>

    </data>
</odoo>
