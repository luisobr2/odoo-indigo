<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_indigo_installation_schedule_wizard" model="ir.ui.view">
        <field name="name">indigo.installation.schedule.wizard.form</field>
        <field name="model">indigo.installation.schedule.wizard</field>
        <field name="arch" type="xml">
            <form string="Schedule Installation">
                <sheet>
                    <div class="oe_title">
                        <h2>Schedule Installation</h2>
                        <p class="text-muted">
                            Pick an existing order and assign it the installation date.
                            To create a new order, go to <b>Indigo &#8594; Orders</b>.
                        </p>
                    </div>
                    <group>
                        <group>
                            <field name="installation_date"/>
                            <field name="order_id"
                                   options="{'no_create': True, 'no_open': True}"/>
                            <field name="installer_ids" widget="many2many_tags"/>
                        </group>
                        <group string="Order details" invisible="not order_id">
                            <field name="dealer_id"/>
                            <field name="client_name"/>
                            <field name="door_count"/>
                            <field name="client_address"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Schedule"
                            name="action_schedule"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_indigo_installation_schedule_wizard" model="ir.actions.act_window">
        <field name="name">Schedule Installation</field>
        <field name="res_model">indigo.installation.schedule.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_indigo_installation_schedule_wizard"/>
        <field name="target">new</field>
    </record>

</odoo>
