<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Card image follows the /shop type+color filter.
         Base template renders <span t-field="image_holder.image_1920"> (the
         product cover). We swap it for the design's per-type-per-color photo
         from /indigo/door_image/<design>/<color>?type=<type>. Default SD+black;
         when a filter is active, that type/color. Non-Indigo products keep the
         native cover (t-else). The selected type/color come from
         website.indigo_shop_filters() (reads request.params — no qcontext
         dependency, works for every render of products_item). -->
    <template id="indigo_shop_card_image" inherit_id="website_sale.products_item"
              name="Indigo: shop card image by type+color" priority="30">
        <xpath expr="//span[@t-field='image_holder.image_1920']" position="replace">
            <t t-set="indigo_f" t-value="website.indigo_shop_filters()"/>
            <t t-set="indigo_itype" t-value="indigo_f['type'] or 'SD'"/>
            <t t-set="indigo_icolor" t-value="indigo_f['color'] or 'black'"/>
            <!-- sudo: the /shop grid is public, and indigo_family_types() reads
                 indigo.design (not public-readable). The design id is a
                 non-sensitive value used only to build the image URL. -->
            <t t-set="indigo_ift"
               t-value="[f for f in product.sudo().indigo_family_types() if f['door_type'] == indigo_itype] if product.is_indigo_design else []"/>
            <t t-set="indigo_idesign"
               t-value="(indigo_ift[0]['design_id'] if indigo_ift else (product.sudo().indigo_design_id.id if product.indigo_design_id else False))"/>
            <t t-if="indigo_idesign">
                <!-- Replicate the native image wrapper exactly so the card
                     layout/sizing (theme + website_sale CSS target this
                     structure) stays identical; only the src changes. -->
                <span class="oe_product_image_img_wrapper d-flex h-100 justify-content-center align-items-center position-absolute">
                    <img t-att-src="'/indigo/door_image/%s/%s?type=%s' % (indigo_idesign, indigo_icolor, indigo_itype)"
                         t-att-alt="product.name" loading="lazy" itemprop="image"
                         class="img img-fluid h-100 w-100 position-absolute object-fit-contain"/>
                </span>
            </t>
            <t t-else="">
                <span t-field="image_holder.image_1920"
                      t-options="{'widget': 'image', 'preview_image': image_type, 'itemprop': 'image', 'class': 'h-100 w-100 position-absolute object-fit-contain'}"/>
            </t>
        </xpath>
    </template>

    <!-- Filter bar above the grid: Door type (All/Single/Double) + Finish
         (All/Black/White/Bronze). Server-side: each link reloads /shop with
         ?type=/?color= (preserving search), which narrows the set by type and
         swaps every card image. Active value highlighted. -->
    <template id="indigo_shop_filter_bar" inherit_id="website_sale.products"
              name="Indigo: shop type+color filter bar" priority="30">
        <xpath expr="//div[hasclass('o_wsale_products_main_row')]" position="before">
            <t t-set="indigo_f" t-value="website.indigo_shop_filters()"/>
            <div class="indigo-shop-filters d-flex flex-wrap align-items-center gap-4 mb-3 pt-2">
                <div class="d-flex align-items-center gap-2">
                    <span class="indigo-eyebrow me-1">Door type</span>
                    <a t-att-href="website.indigo_shop_filter_url(set_type='')"
                       t-attf-class="btn btn-sm rounded-pill #{'btn-primary' if not indigo_f['type'] else 'btn-outline-secondary'}">All</a>
                    <a t-att-href="website.indigo_shop_filter_url(set_type='SD')"
                       t-attf-class="btn btn-sm rounded-pill #{'btn-primary' if indigo_f['type'] == 'SD' else 'btn-outline-secondary'}">Single</a>
                    <a t-att-href="website.indigo_shop_filter_url(set_type='DD')"
                       t-attf-class="btn btn-sm rounded-pill #{'btn-primary' if indigo_f['type'] == 'DD' else 'btn-outline-secondary'}">Double</a>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="indigo-eyebrow me-1">Finish</span>
                    <a t-att-href="website.indigo_shop_filter_url(set_color='')"
                       t-attf-class="btn btn-sm rounded-pill #{'btn-primary' if not indigo_f['color'] else 'btn-outline-secondary'}">All</a>
                    <a t-att-href="website.indigo_shop_filter_url(set_color='black')"
                       t-attf-class="btn btn-sm rounded-pill #{'btn-primary' if indigo_f['color'] == 'black' else 'btn-outline-secondary'}">Black</a>
                    <a t-att-href="website.indigo_shop_filter_url(set_color='white')"
                       t-attf-class="btn btn-sm rounded-pill #{'btn-primary' if indigo_f['color'] == 'white' else 'btn-outline-secondary'}">White</a>
                    <a t-att-href="website.indigo_shop_filter_url(set_color='bronze')"
                       t-attf-class="btn btn-sm rounded-pill #{'btn-primary' if indigo_f['color'] == 'bronze' else 'btn-outline-secondary'}">Bronze</a>
                </div>
            </div>
        </xpath>
    </template>

</odoo>
